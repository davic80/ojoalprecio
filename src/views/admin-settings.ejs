<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ajustes — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/admin/categories" class="nav-link">Categorías</a>
    <a href="/admin/deals" class="nav-link">Chollos</a>
    <a href="/admin/social" class="nav-link">Social</a>
    <a href="/admin/stats" class="nav-link">Stats</a>
    <a href="/admin/users" class="nav-link">Usuarios</a>
    <a href="/admin/settings" class="nav-link nav-link-active">Ajustes</a>
    <span id="scrape-widget" style="position:relative;margin-right:4px"></span>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<main class="container">

  <div class="page-header">
    <h1>Ajustes de sistema</h1>
    <p class="subtitle">Configuración en tiempo real. Los valores de BD tienen prioridad sobre las variables de entorno. Cambios efectivos en el siguiente ciclo sin reiniciar.</p>
  </div>

  <!-- System load -->
  <div class="card" style="padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;gap:24px;flex-wrap:wrap">
    <div>
      <div style="font-size:11px;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">Carga del sistema</div>
      <div id="sys-load" style="font-size:15px;font-weight:600;font-family:monospace;color:var(--gray-900)">—</div>
      <div style="font-size:11px;color:var(--gray-400);margin-top:2px">1 min · 5 min · 15 min</div>
    </div>
    <div>
      <div style="font-size:11px;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">RAM libre</div>
      <div id="sys-mem" style="font-size:15px;font-weight:600;font-family:monospace;color:var(--gray-900)">—</div>
    </div>
    <div>
      <div style="font-size:11px;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px">Uptime</div>
      <div id="sys-uptime" style="font-size:15px;font-weight:600;font-family:monospace;color:var(--gray-900)">—</div>
    </div>
    <div style="margin-left:auto;font-size:11px;color:var(--gray-300)" id="sys-ts"></div>
  </div>

  <div class="card">
    <% settings.forEach(function(s, i) { %>
      <div style="<%= i > 0 ? 'border-top:1px solid var(--gray-100);' : '' %>padding:16px 0;display:flex;align-items:flex-start;gap:16px;flex-wrap:wrap">

        <div style="flex:1;min-width:220px">
          <div style="font-size:14px;font-weight:600;color:var(--gray-800)"><%= s.label %></div>
          <% if (s.hint) { %>
            <div class="hint" style="margin-top:3px"><%= s.hint %></div>
          <% } %>
          <div class="hint" style="margin-top:3px">
            Env var por defecto: <code style="background:var(--gray-100);padding:1px 5px;border-radius:3px"><%= envDefaults[s.key] ?? '—' %></code>
          </div>
        </div>

        <div style="display:flex;align-items:center;gap:10px;flex-shrink:0">
          <% if (s.valueType === 'boolean') { %>
            <form
              hx-post="/admin/settings/<%= s.key %>"
              hx-target="#saved-<%= s.key %>"
              hx-swap="outerHTML"
            >
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
                <input type="hidden" name="value" value="false">
                <input
                  type="checkbox"
                  name="value"
                  value="true"
                  <%= s.value === 'true' ? 'checked' : '' %>
                  style="width:18px;height:18px;cursor:pointer;accent-color:var(--primary)"
                  onchange="this.form.requestSubmit()"
                >
                <span style="font-size:13px;font-weight:500"><%= s.value === 'true' ? 'Activo' : 'Inactivo' %></span>
              </label>
            </form>
          <% } else { %>
            <form
              hx-post="/admin/settings/<%= s.key %>"
              hx-target="#saved-<%= s.key %>"
              hx-swap="outerHTML"
              style="display:flex;align-items:center;gap:8px"
            >
              <input
                type="number"
                name="value"
                value="<%= s.value %>"
                class="input"
                style="width:90px;text-align:right;padding:6px 10px"
                <% if (s.key === 'scraper_concurrency')    { %>min="1"  max="8"   <% } %>
                <% if (s.key === 'retry_failed_per_cycle') { %>min="0"  max="100" <% } %>
                <% if (s.key === 'scraper_timeout_seconds'){ %>min="15" max="120" <% } %>
                <% if (s.key === 'min_age_minutes')        { %>min="30" max="1440"<% } %>
              >
              <button type="submit" class="btn btn-primary btn-sm">Guardar</button>
            </form>
          <% } %>
          <span id="saved-<%= s.key %>" style="font-size:12px;color:var(--success,#16a34a);min-width:70px"></span>
        </div>

      </div>
    <% }); %>
  </div>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> Admin &nbsp;·&nbsp; <a href="/ofertas">Ver ofertas públicas</a></p>
</footer>

<style>
.setting-saved { font-size:12px; color:var(--success,#16a34a); animation: fadeout 3s forwards; }
@keyframes fadeout { 0%,70% { opacity:1 } 100% { opacity:0 } }
</style>
<script src="/js/scrape-widget.js"></script>
<script>
(function () {
  function fmtUptime(s) {
    var d = Math.floor(s / 86400), h = Math.floor((s % 86400) / 3600), m = Math.floor((s % 3600) / 60);
    if (d > 0) return d + 'd ' + h + 'h';
    if (h > 0) return h + 'h ' + m + 'm';
    return m + 'm';
  }
  function poll() {
    fetch('/admin/system-stats').then(function (r) { return r.json(); }).then(function (d) {
      var load = d.load;
      var usedMb = d.mem.totalMb - d.mem.freeMb;
      var pct = Math.round(usedMb / d.mem.totalMb * 100);
      var loadColor = parseFloat(load.l1) > 3 ? 'var(--red,#dc2626)' : parseFloat(load.l1) > 1.5 ? 'var(--orange,#ea580c)' : 'var(--gray-900)';
      document.getElementById('sys-load').style.color = loadColor;
      document.getElementById('sys-load').textContent  = load.l1 + ' · ' + load.l5 + ' · ' + load.l15;
      document.getElementById('sys-mem').textContent   = usedMb + ' / ' + d.mem.totalMb + ' MB (' + pct + '%)';
      document.getElementById('sys-uptime').textContent = fmtUptime(d.uptime);
      document.getElementById('sys-ts').textContent    = 'actualizado ' + new Date().toLocaleTimeString('es-ES');
    }).catch(function () {});
  }
  poll();
  setInterval(poll, 10000);
})();
</script>
</body>
</html>
