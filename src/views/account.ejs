<!DOCTYPE html>
<html lang="es">
<head>
<%- include('partials/head', { title: 'Mi cuenta — OjoAlPrecio', includeHtmx: true }) %>
</head>
<body>

<%- include('partials/navbar', { variant: 'account', user }) %>

<main class="container">

  <div class="back-link">
    <a href="/">← Volver al dashboard</a>
  </div>

  <div class="page-header">
    <h1>Mi cuenta</h1>
    <p class="subtitle"><%= user.email %></p>
  </div>

  <% if (success) { %>
    <div class="alert-box" style="background:#f0fdf4; border:1px solid #bbf7d0; color:#166534; margin-bottom:20px">
      Contraseña actualizada correctamente.
    </div>
  <% } %>

  <!-- Change password -->
  <div class="card" style="margin-bottom:20px; max-width:440px">
    <h2>Cambiar contraseña</h2>
    <% if (error) { %>
      <div class="alert-box alert-error" style="margin-top:12px"><%= error %></div>
    <% } %>
    <form action="/account/change-password" method="POST" class="auth-form" style="margin-top:16px">
      <div class="form-field">
        <label for="currentPassword">Contraseña actual</label>
        <input type="password" name="currentPassword" id="currentPassword" class="input" required autocomplete="current-password">
      </div>
      <div class="form-field">
        <label for="newPassword">Nueva contraseña</label>
        <input type="password" name="newPassword" id="newPassword" class="input" required autocomplete="new-password" minlength="8">
      </div>
      <div class="form-field">
        <label for="confirmPassword">Repite la contraseña</label>
        <input type="password" name="confirmPassword" id="confirmPassword" class="input" required autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top:4px">Guardar contraseña</button>
    </form>
  </div>

  <!-- Alerts -->
  <div class="card">
    <h2>Mis alertas</h2>
    <p class="subtitle">Todas las alertas de precio activas e inactivas.</p>

    <% if (alerts.length === 0) { %>
      <p class="hint" style="margin-top:16px">No tienes alertas configuradas. Puedes crearlas desde la ficha de cada producto.</p>
    <% } else { %>
    <div class="table-wrap" style="margin-top:16px" id="alerts-list">
      <table class="price-table table-card-mobile">
        <thead>
          <tr>
            <th>Producto</th>
            <th>Condición</th>
            <th>Notificación</th>
            <th>Estado</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% alerts.forEach(function(a) {
            const fired = !!a.notifiedAt;
            let condition = '';
            if (a.alertType === 'price' && a.thresholdPrice) {
              condition = 'Precio < ' + parseFloat(a.thresholdPrice).toFixed(2) + ' €';
            } else if (a.alertType === 'percent' && a.percentageDrop) {
              condition = 'Bajada > ' + parseFloat(a.percentageDrop).toFixed(1) + '%';
            } else if (a.alertType === 'alltime_low') {
              condition = 'Nuevo mínimo histórico';
            } else if (a.alertType === 'stock') {
              condition = 'Vuelta en stock';
            }
          %>
          <tr id="alert-row-<%= a.id %>">
            <td data-label="Producto">
              <a href="/p/<%= a.productAsin %>" style="font-weight:500; font-size:13px">
                <%= a.productName ? (a.productName.length > 50 ? a.productName.slice(0,50) + '…' : a.productName) : a.productAsin %>
              </a>
            </td>
            <td data-label="Condición" style="font-size:13px"><%= condition %></td>
            <td data-label="Notificación" style="font-size:12px; color:var(--gray-500)">
              <%= a.notificationChannel === 'telegram' ? 'Telegram' : a.notificationChannel === 'both' ? 'Email + TG' : a.notificationEmail %>
            </td>
            <td data-label="Estado">
              <% if (fired) { %>
                <span class="alert-badge badge-triggered">Disparada</span>
              <% } else if (a.isActive) { %>
                <span class="alert-badge badge-active">Activa</span>
              <% } else { %>
                <span class="alert-badge badge-triggered">Inactiva</span>
              <% } %>
            </td>
            <td>
              <div class="alert-actions">
                <% if (fired) { %>
                  <button
                    class="btn btn-sm btn-outline"
                    hx-patch="/alerts/<%= a.id %>/reset"
                    hx-target="#alert-row-<%= a.id %>"
                    hx-swap="outerHTML"
                    title="Reactivar alerta"
                  >Reactivar</button>
                <% } %>
                <button
                  class="btn btn-sm btn-danger"
                  hx-delete="/alerts/<%= a.id %>"
                  hx-target="#alert-row-<%= a.id %>"
                  hx-swap="outerHTML"
                  hx-confirm="¿Eliminar esta alerta?"
                >Eliminar</button>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <%# AliExpress alerts — only shown when the user follows at least one AE
     product. Threshold edit is inline per row, POSTing to the same endpoint
     /ae/:productId/threshold used on the product page. Empty value clears
     the threshold and disables the alert. -%>
  <% if (typeof aliexpressTracks !== 'undefined' && aliexpressTracks.length > 0) { %>
    <div class="card">
      <h2>Alertas AliExpress
        <span class="marketplace-tag marketplace-tag-aliexpress" style="margin-left:var(--sp-2);font-size:var(--fs-xs)">🛒 <%= aliexpressTracks.length %></span>
      </h2>
      <p class="subtitle">Fija un umbral en cada producto seguido y te avisaremos cuando el precio caiga por debajo.</p>

      <div class="table-wrap" style="margin-top:var(--sp-3)">
        <table class="price-table table-card-mobile">
          <thead>
            <tr>
              <th>Producto</th>
              <th>Precio actual</th>
              <th>Umbral</th>
              <th>Estado</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% aliexpressTracks.forEach(function(t) { %>
              <tr>
                <td data-label="Producto">
                  <a href="/ae/<%= t.productId %>" style="font-weight:500;font-size:13px">
                    <%= t.title.length > 60 ? t.title.slice(0, 60) + '…' : t.title %>
                  </a>
                </td>
                <td data-label="Precio actual" style="font-size:13px;font-variant-numeric:tabular-nums">
                  <%= t.salePrice ? t.salePrice.toFixed(2) + ' €' : '—' %>
                </td>
                <td data-label="Umbral">
                  <form method="POST" action="/ae/<%= t.productId %>/threshold" style="display:flex;gap:var(--sp-1);align-items:center">
                    <input
                      type="text"
                      name="threshold"
                      inputmode="decimal"
                      value="<%= t.thresholdPrice !== null ? t.thresholdPrice.toFixed(2) : '' %>"
                      placeholder="<%= t.salePrice ? (t.salePrice * 0.9).toFixed(2) : '—' %>"
                      class="input input-sm"
                      style="width:90px;font-variant-numeric:tabular-nums"
                      aria-label="Umbral en euros"
                    >
                    <button type="submit" class="btn btn-sm btn-outline" title="Guardar umbral">✓</button>
                  </form>
                </td>
                <td data-label="Estado">
                  <% if (!t.isAvailable) { %>
                    <span class="alert-badge badge-triggered">Sin stock</span>
                  <% } else if (t.thresholdPrice === null) { %>
                    <span class="alert-badge badge-triggered">Sin alerta</span>
                  <% } else if (t.notifiedAt !== null) { %>
                    <span class="alert-badge badge-triggered">Disparada</span>
                  <% } else { %>
                    <span class="alert-badge badge-active">Activa</span>
                  <% } %>
                </td>
                <td>
                  <a href="/ae/<%= t.productId %>" class="btn btn-sm btn-ghost" title="Ver producto">→</a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <p class="hint" style="margin-top:var(--sp-3)">
        Deja un umbral vacío y pulsa <strong>✓</strong> para desactivar esa alerta.
      </p>
    </div>
  <% } %>

</main>

<%- include('partials/footer', { middleHtml: '<a href="/ofertas">Ver ofertas</a>', showTelegram: false }) %>

<%- include('partials/bottom-nav', { user: user, activeNav: 'cuenta' }) %>

</body>
</html>
