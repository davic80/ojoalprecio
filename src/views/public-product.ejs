<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name ?? product.asin %> — Historial de precio en Amazon.es | OjoAlPrecio</title>
  <meta name="description" content="Historial de precio de <%= product.name ?? product.asin %> en Amazon.es. Precio actual: <%= currentPrice ? currentPrice.toFixed(2) + ' €' : 'N/D' %>. Mínimo histórico: <%= minPrice ? minPrice.toFixed(2) + ' €' : 'N/D' %>.">
  <link rel="canonical" href="<%= siteUrl %>/p/<%= product.asin %>">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/ofertas" class="nav-link">Ofertas</a>
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/" class="nav-link">Mi panel</a>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
    <% } else { %>
      <a href="/auth/login?next=<%= encodeURIComponent('/p/' + product.asin) %>" class="btn btn-outline btn-sm">Entrar</a>
    <% } %>
  </div>
</nav>

<main class="container">

  <div class="back-link"><a href="/ofertas">← Ver todas las ofertas</a></div>

  <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:8px 12px;margin-bottom:16px;font-size:13px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
      <strong style="color:#475569">🔧 Admin</strong>
      <form hx-post="/products/<%= product.id %>/refresh" hx-swap="none" style="display:inline;margin:0">
        <button type="submit" class="btn btn-sm btn-ghost" title="Re-scrapear ahora">↺ Refresh</button>
      </form>
      <form hx-post="/products/<%= product.id %>/toggle-public" hx-swap="none" style="display:inline;margin:0">
        <button type="submit" class="btn btn-sm <%= product.isFeatured ? 'btn-outline btn-active-green' : 'btn-ghost' %>"
          title="Aparece en /ofertas">
          <%= product.isFeatured ? '✨ Destacado' : '📣 Destacar en /ofertas' %>
        </button>
      </form>
      <span style="flex:1"></span>
      <a href="/products/<%= product.id %>" class="hint" style="font-size:12px;color:#64748b">vista interna ↗</a>
    </div>
  <% } %>

  <!-- Product header -->
  <div class="product-header">
    <% if (product.imageUrl) { %>
      <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="product-detail-img">
    <% } %>
    <div class="product-header-info">
      <h1><%= product.name ?? product.asin %></h1>
      <p class="product-asin">ASIN: <strong><%= product.asin %></strong></p>
      <a href="<%= product.amazonUrl %>" target="_blank" rel="noopener sponsored" class="amazon-link">
        Ver en Amazon.es ↗
      </a>
    </div>

    <div class="price-stats">
      <div class="stat-box stat-current">
        <div class="stat-label">Precio actual</div>
        <div class="stat-value"><%= currentPrice ? currentPrice.toFixed(2) + ' €' : '—' %></div>
        <% if (currentPrice && minPrice && currentPrice > minPrice + 0.01) {
             const diffAbs = (currentPrice - minPrice).toFixed(2);
             const diffPct = Math.round((currentPrice - minPrice) / minPrice * 100);
        %>
          <div class="stat-sublabel stat-above-min">+<%= diffAbs %> € vs mínimo (<%= diffPct %>%)</div>
        <% } else if (currentPrice && minPrice && currentPrice <= minPrice + 0.01) { %>
          <div class="stat-sublabel stat-at-min">Precio mínimo histórico</div>
        <% } %>
      </div>
      <div class="stat-box stat-min">
        <div class="stat-label">Precio mínimo</div>
        <div class="stat-value"><%= minPrice ? minPrice.toFixed(2) + ' €' : '—' %></div>
        <% if (minPrice) { %><div class="stat-sublabel">desde <%= new Date(product.createdAt).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' }) %></div><% } %>
      </div>
      <div class="stat-box stat-max">
        <div class="stat-label">Precio máximo</div>
        <div class="stat-value"><%= maxPrice ? maxPrice.toFixed(2) + ' €' : '—' %></div>
      </div>
      <div class="stat-box stat-checks">
        <div class="stat-label">Registros</div>
        <div class="stat-value"><%= history.length %></div>
      </div>
    </div>
  </div>

  <div class="cta-bar">
    <a href="<%= product.amazonUrl %>" target="_blank" rel="noopener sponsored" class="btn btn-primary">
      Comprar en Amazon.es — <%= currentPrice ? currentPrice.toFixed(2) + ' €' : 'Ver precio' %>
    </a>
    <%
      const isLogged    = typeof user      !== 'undefined' && user;
      const followsThis = typeof userFollows !== 'undefined' && userFollows;
    %>
    <% if (!isLogged) { %>
      <a href="/auth/register?next=<%= encodeURIComponent('/p/' + product.asin) %>&intent=alert" class="btn btn-outline">Crear alerta de precio gratis</a>
    <% } else if (!followsThis) { %>
      <form method="POST" action="/products" style="display:inline">
        <input type="hidden" name="url" value="<%= product.amazonUrl %>">
        <input type="hidden" name="next" value="/p/<%= product.asin %>">
        <button type="submit" class="btn btn-outline">+ Seguir y crear alerta 1%</button>
      </form>
    <% } %>
  </div>

  <% if (isLogged && followsThis) { %>
    <div class="card" style="margin-top:24px">
      <h2 style="margin-top:0">Tus alertas para este producto</h2>
      <% if (userAlerts && userAlerts.length) { %>
        <ul style="list-style:none;padding:0;margin:0 0 12px">
          <% userAlerts.forEach(function(a) {
               const refP = a.referencePrice ? parseFloat(a.referencePrice) : null;
               const label = a.alertType === 'percent'
                 ? '−' + parseFloat(a.percentageDrop).toFixed(0) + '%' + (refP ? ' desde ' + refP.toFixed(2) + ' €' : ' (pendiente primer precio)')
                 : a.alertType === 'price'
                 ? '≤ ' + parseFloat(a.thresholdPrice).toFixed(2) + ' €'
                 : a.alertType === 'alltime_low'
                 ? 'Mínimo histórico'
                 : 'Stock';
          %>
            <li style="padding:8px 0;border-bottom:1px solid var(--border,#eee);display:flex;justify-content:space-between;align-items:center;gap:12px">
              <span>
                <strong><%= label %></strong>
                <% if (a.isDefault) { %><span class="badge" style="font-size:0.75em;background:#eef;color:#447;padding:2px 6px;border-radius:4px;margin-left:6px">auto</span><% } %>
                <span style="color:#666;font-size:0.9em">· <%= a.notificationChannel %> → <%= a.notificationEmail %></span>
              </span>
              <button type="button"
                class="btn btn-sm btn-outline"
                hx-delete="/alerts/<%= a.id %>"
                hx-confirm="¿Borrar esta alerta?"
                hx-target="closest li"
                hx-swap="outerHTML">Borrar</button>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <p class="hint">Aún no tienes alertas configuradas para este producto.</p>
      <% } %>

      <details style="margin-top:12px">
        <summary style="cursor:pointer;font-weight:500">+ Configurar nueva alerta</summary>
        <form method="POST" action="/products/<%= product.id %>/alerts" style="margin-top:12px;display:flex;flex-direction:column;gap:8px;max-width:480px">
          <label>
            Tipo
            <select name="alertType" required>
              <option value="percent">Bajada de %</option>
              <option value="price">Precio máximo (€)</option>
              <option value="alltime_low">Cualquier mínimo histórico</option>
            </select>
          </label>
          <label>
            % de bajada / precio umbral
            <input type="number" step="0.01" name="percentageDrop" placeholder="Ej: 10" />
            <input type="number" step="0.01" name="thresholdPrice" placeholder="Ej: 99.00" />
          </label>
          <label>
            Email
            <input type="email" name="notificationEmail" value="<%= user.email %>" required>
          </label>
          <input type="hidden" name="notificationChannel" value="email">
          <button type="submit" class="btn btn-primary">Crear alerta</button>
        </form>
      </details>
    </div>
  <% } %>

  <% if (history.length > 0) { %>
    <div class="card chart-card">
      <h2>Historial de precios</h2>
      <div class="chart-wrap">
        <canvas id="priceChart"></canvas>
      </div>
    </div>

    <%
      const tableRows = history.slice(0, 50);
      const tablePrices = tableRows.map(h => parseFloat(h.price));
      const tableMin = Math.min(...tablePrices);
      const tableMax = Math.max(...tablePrices);
    %>
    <div class="card history-table-card">
      <h2>Últimos registros</h2>
      <div class="history-table-wrap">
        <table class="history-table">
          <thead>
            <tr><th>Fecha</th><th>Precio</th><th>Variación</th></tr>
          </thead>
          <tbody>
            <% tableRows.forEach(function(h, i) {
              const price = parseFloat(h.price);
              const prev  = i + 1 < tableRows.length ? parseFloat(tableRows[i + 1].price) : null;
              const delta = prev !== null ? price - prev : null;
              const isMin = Math.abs(price - tableMin) < 0.005;
              const isMax = Math.abs(price - tableMax) < 0.005;
            %>
            <tr class="<%= isMin ? 'row-min' : isMax ? 'row-max' : '' %>">
              <td><%= new Date(h.scrapedAt).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
              <td class="price-cell">
                <%= price.toFixed(2) %> €
                <% if (isMin) { %><span class="badge-min-inline">mín</span><% } %>
                <% if (isMax) { %><span class="badge-max-inline">máx</span><% } %>
              </td>
              <td class="delta-cell">
                <% if (delta !== null) { %>
                  <span class="<%= delta < 0 ? 'delta-down' : delta > 0 ? 'delta-up' : 'delta-flat' %>">
                    <%= delta > 0 ? '+' : '' %><%= delta.toFixed(2) %> €
                  </span>
                <% } else { %>—<% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% if (history.length > 50) { %>
        <p class="table-note">Mostrando los 50 registros más recientes de <%= history.length %> totales.</p>
      <% } %>
    </div>

    <script>
      const chartData = <%- JSON.stringify(
        history.slice().reverse().map(h => ({
          x: new Date(h.scrapedAt).toISOString(),
          y: parseFloat(h.price)
        }))
      ) %>;
      document.addEventListener('DOMContentLoaded', () => {
        const ctx = document.getElementById('priceChart').getContext('2d');
        new Chart(ctx, {
          type: 'line',
          data: {
            datasets: [{
              label: 'Precio (€)', data: chartData,
              borderColor: '#e63946', backgroundColor: 'rgba(230,57,70,0.08)',
              borderWidth: 2, pointRadius: chartData.length > 100 ? 0 : 3,
              pointHoverRadius: 5, tension: 0.2, fill: true,
            }]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: { display: false },
              tooltip: { callbacks: { label: ctx => ctx.parsed.y.toFixed(2) + ' €' } }
            },
            scales: {
              x: { type: 'time', time: { tooltipFormat: 'dd/MM/yyyy HH:mm', displayFormats: { hour: 'dd/MM HH:mm', day: 'dd/MM', month: 'MMM yyyy' } }, grid: { color: 'rgba(0,0,0,0.05)' } },
              y: { ticks: { callback: v => v.toFixed(2) + ' €' }, grid: { color: 'rgba(0,0,0,0.05)' } }
            }
          }
        });
      });
    </script>
  <% } %>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> &nbsp;·&nbsp; Seguimiento de precios en Amazon.es &nbsp;·&nbsp; <a href="/auth/register">Crea tu cuenta gratis</a><% if (process.env.TELEGRAM_PUBLIC_CHANNEL) { %> &nbsp;·&nbsp; <a href="https://t.me/<%= process.env.TELEGRAM_PUBLIC_CHANNEL.replace('@','') %>" target="_blank" rel="noopener">📢 Telegram</a><% } %></p>
</footer>

</body>
</html>
