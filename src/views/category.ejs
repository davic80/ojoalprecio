<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= category.name %> — OjoAlPrecio</title>
  <meta name="description" content="Productos de <%= category.name %> en Amazon.es con seguimiento de precios.">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar', { variant: 'anonymous' }) %>

<main class="container-wide">

  <div class="page-header">
    <h1><%= category.name %></h1>
    <p class="subtitle">
      <a href="/ofertas" class="hint-link">← Ver todas las ofertas</a>
    </p>
  </div>

  <% if (deals.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">🔍</div>
      <h3>Sin productos publicados en esta categoría</h3>
      <p>Cuando haya productos en oferta en esta categoría aparecerán aquí.</p>
    </div>
  <% } else { %>
    <div class="product-grid">
      <% deals.forEach(function(d) { %>
        <%- include('partials/deal-card', { d: d, showOfferFallback: false, isAdmin: typeof isAdmin !== 'undefined' && isAdmin }) %>
      <% }); %>
    </div>
  <% } %>

</main>

<%- include('partials/footer', { middleHtml: '<a href="/auth/login">Añade tus productos</a>' }) %>

<style>
.sparkline-svg { display: block; margin-top: 6px; }
.product-img-wrap[data-images] { cursor: pointer; }
</style>
<script>
(function() {
  document.querySelectorAll('.product-img-wrap[data-images]').forEach(function(wrap) {
    const images = JSON.parse(wrap.dataset.images);
    if (images.length < 2) return;
    const img = wrap.querySelector('.product-img');
    if (!img) return;
    let idx = 0, timer = null;
    wrap.addEventListener('mouseenter', function() {
      timer = setInterval(function() {
        idx = (idx + 1) % images.length;
        img.src = images[idx];
      }, 2000);
    });
    wrap.addEventListener('mouseleave', function() {
      clearInterval(timer);
      timer = null;
      idx = 0;
      img.src = images[0];
    });
  });
})();

document.querySelectorAll('.public-toggle').forEach(function(btn) {
  btn.addEventListener('click', async function() {
    const id = btn.dataset.id;
    btn.disabled = true;
    try {
      const res = await fetch('/products/' + id + '/toggle-public', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      const data = await res.json();
      btn.textContent = data.isPublic ? 'Destacado' : 'No destacado';
      btn.style.background = data.isPublic ? '#16a34a' : '';
      btn.style.color = data.isPublic ? '#fff' : '';
      btn.style.borderColor = data.isPublic ? '#16a34a' : '';
      btn.style.opacity = data.isPublic ? '1' : '.6';
    } catch(e) { console.error(e); }
    btn.disabled = false;
  });
});
</script>
<%- include('partials/bottom-nav', { user: typeof user !== 'undefined' ? user : null, activeNav: 'ofertas' }) %>

</body>
</html>
