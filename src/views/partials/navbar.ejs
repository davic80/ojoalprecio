<%#
  User-facing navbar partial. Locals:
    variant : 'deals' | 'user' | 'anonymous' | 'product' | 'account'  (required)

  Variant-specific locals:
    deals      : user (optional), isAdmin (optional)
    user       : user (required), isAdmin (optional)
    anonymous  : (none)
    product    : isLogged (required), user (if logged), adminMode (optional),
                 product (required, for the login next=URL)
    account    : user (required)
%>
<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <%# Universal search — visible on tablet+ (mobile has the bottom-nav entry).
     Keeps a single GET form to /search across all variants so users can jump
     anywhere → search in one click. Uses the design-system .input class so
     it matches every other text field on the site. -%>
  <form method="GET" action="/search" class="navbar-search" role="search">
    <input type="search" name="q" value="<%= typeof q !== 'undefined' ? q : '' %>"
           placeholder="Buscar producto…" aria-label="Buscar productos"
           class="input">
  </form>
  <div class="navbar-actions">
<%_ if (variant === 'deals') { _%>
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/" class="nav-link">Mi dashboard</a>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
      <a href="/account" class="user-email user-email-link"><%= user.email %></a>
      <form action="/auth/logout" method="POST" style="display:inline">
        <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
      </form>
    <% } else { %>
      <a href="/auth/login" class="btn btn-outline btn-sm">Entrar</a>
    <% } %>
<%_ } else if (variant === 'user') { _%>
    <a href="/ofertas" class="nav-link">Ofertas</a>
    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
      <a href="/admin/categories" class="nav-link">Admin</a>
    <% } %>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
<%_ } else if (variant === 'anonymous') { _%>
    <a href="/ofertas" class="nav-link">Ofertas</a>
    <a href="/auth/login" class="btn btn-outline btn-sm">Entrar</a>
<%_ } else if (variant === 'product') { _%>
    <a href="/ofertas" class="nav-link">Ofertas</a>
    <% if (isLogged) { %>
      <a href="/" class="nav-link">Mi panel</a>
      <% if (adminMode) { %>
        <a href="/admin" class="nav-link">Admin</a>
      <% } %>
      <a href="/account" class="user-email user-email-link"><%= user.email %></a>
      <form action="/auth/logout" method="POST" style="display:inline">
        <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
      </form>
    <% } else { %>
      <a href="/auth/login?next=<%= encodeURIComponent('/p/' + product.asin) %>" class="btn btn-outline btn-sm">Entrar</a>
    <% } %>
<%_ } else if (variant === 'account') { _%>
    <a href="/account" class="user-email user-email-link nav-link-active"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
<%_ } _%>
  </div>
</nav>
