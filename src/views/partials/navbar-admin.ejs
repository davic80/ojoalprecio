<%_
  // Admin navbar partial — grouped dropdowns. Locals:
  //   user        : { email }                            (required)
  //   activePage  : 'categories' | 'deals' | 'cleanup' | 'anomalies'
  //               | 'users' | 'alerts'
  //               | 'aliexpress' | 'affiliates'
  //               | 'stats' | 'social' | 'ops'
  //               | 'settings'                           (optional)
  //   showHubLink : boolean — render leading "/admin"    (optional)
  //
  // The 11-item flat layout from earlier ran out of horizontal room. Now
  // 4 dropdowns + Ajustes suelto, with the trigger highlighted when any
  // of its children is the active page.
  const PAGE_GROUPS = {
    categories: 'catalog', deals: 'catalog', anomalies: 'catalog', cleanup: 'catalog',
    users: 'users', alerts: 'users',
    aliexpress: 'marketplaces', affiliates: 'marketplaces',
    stats: 'data', social: 'data', ops: 'data',
  };
  const _ap = typeof activePage !== 'undefined' ? activePage : null;
  const _activeGroup = _ap ? PAGE_GROUPS[_ap] : null;
  const _item    = (p) => 'admin-menu-item' + (_ap === p ? ' admin-menu-item-active' : '');
  const _trigger = (g) => 'admin-menu-trigger' + (_activeGroup === g ? ' admin-menu-trigger-active' : '');
  const _showHub = typeof showHubLink !== 'undefined' && showHubLink;
_%>
<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <%_ if (_showHub) { _%>
    <a href="/admin" class="nav-link">Admin</a>
    <%_ } _%>

    <div class="admin-menu">
      <button type="button" class="<%= _trigger('catalog') %>" aria-haspopup="true" aria-expanded="false">📦 Catálogo ▾</button>
      <div class="admin-menu-panel" hidden>
        <a href="/admin/categories" class="<%= _item('categories') %>">Categorías</a>
        <a href="/admin/deals"      class="<%= _item('deals') %>">Chollos</a>
        <a href="/admin/anomalies"  class="<%= _item('anomalies') %>">⚠ Anomalías</a>
        <a href="/admin/cleanup"    class="<%= _item('cleanup') %>">🧹 Limpieza</a>
      </div>
    </div>

    <div class="admin-menu">
      <button type="button" class="<%= _trigger('users') %>" aria-haspopup="true" aria-expanded="false">👥 Usuarios ▾</button>
      <div class="admin-menu-panel" hidden>
        <a href="/admin/users"  class="<%= _item('users') %>">Usuarios</a>
        <a href="/admin/alerts" class="<%= _item('alerts') %>">Alertas</a>
      </div>
    </div>

    <div class="admin-menu">
      <button type="button" class="<%= _trigger('marketplaces') %>" aria-haspopup="true" aria-expanded="false">🛒 Marketplaces ▾</button>
      <div class="admin-menu-panel" hidden>
        <a href="/admin/aliexpress"  class="<%= _item('aliexpress') %>">AliExpress</a>
        <a href="/admin/affiliates"  class="<%= _item('affiliates') %>">€ Amazon</a>
      </div>
    </div>

    <div class="admin-menu">
      <button type="button" class="<%= _trigger('data') %>" aria-haspopup="true" aria-expanded="false">📊 Datos ▾</button>
      <div class="admin-menu-panel" hidden>
        <a href="/admin/ops"    class="<%= _item('ops') %>">🩺 Ops</a>
        <a href="/admin/stats"  class="<%= _item('stats') %>">Stats</a>
        <a href="/admin/social" class="<%= _item('social') %>">Social</a>
      </div>
    </div>

    <a href="/admin/settings" class="nav-link<%= _ap === 'settings' ? ' nav-link-active' : '' %>">⚙️ Ajustes</a>

    <span id="scrape-widget" style="position:relative;margin-right:4px"></span>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<script>
// Click-to-toggle admin dropdowns. Wrapped in DOMContentLoaded so the
// inline tag doesn't block HTML parsing (the partial sits at the top of
// every admin page — even ~5 ms of synchronous JS made the menu feel
// laggy when stacked with the page render). Elements are cached once
// after the DOM is ready so click handlers don't re-querySelector.
document.addEventListener('DOMContentLoaded', function () {
  const menus = [...document.querySelectorAll('.admin-menu')]
    .map(m => ({ trigger: m.querySelector('.admin-menu-trigger'), panel: m.querySelector('.admin-menu-panel') }))
    .filter(m => m.trigger && m.panel);
  let anyOpen = false;

  function closeAll() {
    if (!anyOpen) return;
    for (const { trigger, panel } of menus) {
      panel.setAttribute('hidden', '');
      trigger.setAttribute('aria-expanded', 'false');
    }
    anyOpen = false;
  }
  function positionPanel(trigger, panel) {
    // The panel is position:fixed (to escape navbar-actions' overflow
    // clipping), so we compute viewport coords from the trigger each open.
    // Right-align if it'd spill off the right edge of the viewport.
    const r = trigger.getBoundingClientRect();
    const minW = 200;
    panel.style.top = (r.bottom + 4) + 'px';
    if (r.left + minW > window.innerWidth) {
      panel.style.left = 'auto';
      panel.style.right = Math.max(4, window.innerWidth - r.right) + 'px';
    } else {
      panel.style.left = r.left + 'px';
      panel.style.right = 'auto';
    }
  }

  for (const { trigger, panel } of menus) {
    trigger.addEventListener('click', e => {
      e.stopPropagation();
      const wasOpen = !panel.hasAttribute('hidden');
      closeAll();
      if (!wasOpen) {
        positionPanel(trigger, panel);
        panel.removeAttribute('hidden');
        trigger.setAttribute('aria-expanded', 'true');
        anyOpen = true;
      }
    });
  }
  document.addEventListener('click', closeAll);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeAll(); });
});
</script>
