<!DOCTYPE html>
<html lang="es">
<head>
<%- include('partials/head', { title: 'Crear cuenta — OjoAlPrecio' }) %>
</head>
<body class="auth-page">

<%- include('partials/auth-card-header', { tagline: 'Crea tu cuenta' }) %>

  <% if (error) { %>
    <div class="alert-box alert-error"><%= error %></div>
  <% } %>

  <form action="/auth/register" method="POST" class="auth-form">
    <% if (typeof next !== 'undefined' && next) { %><input type="hidden" name="next" value="<%= next %>"><% } %>
    <div class="form-field">
      <label for="email">Email</label>
      <input
        type="email"
        name="email"
        id="email"
        value="<%= email %>"
        required
        autocomplete="email"
        class="input"
        placeholder="tu@email.com"
      >
    </div>
    <div class="form-field">
      <label for="password">Contraseña</label>
      <input
        type="password"
        name="password"
        id="password"
        required
        autocomplete="new-password"
        class="input"
        placeholder="Mínimo 8 caracteres"
        minlength="8"
      >
    </div>
    <div class="form-field">
      <label for="passwordConfirm">Confirmar contraseña</label>
      <input
        type="password"
        name="passwordConfirm"
        id="passwordConfirm"
        required
        autocomplete="new-password"
        class="input"
        placeholder="Repite tu contraseña"
      >
    </div>
    <button type="submit" class="btn btn-primary btn-full">Crear cuenta</button>
  </form>

  <p class="auth-alt">
    ¿Ya tienes cuenta? <a href="/auth/login">Inicia sesión</a>
  </p>
</div>

</body>
</html>
