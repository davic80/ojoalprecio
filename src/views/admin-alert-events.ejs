<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Historial de alertas — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
</head>
<body>

<%- include('partials/navbar-admin', { user, activePage: 'stats' }) %>

<main class="container">

  <div class="page-header">
    <h1>Historial de alertas disparadas</h1>
    <p class="subtitle">Últimas 200 alertas que han notificado al usuario.</p>
    <div style="display:flex;gap:12px;margin-top:8px;border-bottom:1px solid var(--border,#e2e8f0);padding-bottom:8px">
      <a href="/admin/alerts" class="hint-link">Configuradas</a>
      <a href="/admin/alerts/events" class="hint-link" style="font-weight:600;color:var(--gray-900)">Disparadas</a>
    </div>
  </div>

  <div class="card">
    <% if (events.length === 0) { %>
      <p class="hint" style="margin-top:12px">No hay alertas disparadas todavía.</p>
    <% } else { %>
      <div class="table-wrap">
        <table class="price-table">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Producto</th>
              <th>Tipo</th>
              <th>Precio</th>
              <th>Umbral</th>
              <th>Usuario</th>
            </tr>
          </thead>
          <tbody>
            <% events.forEach(function(ev) { %>
              <tr>
                <td style="white-space:nowrap; font-size:12px; color:var(--gray-500)">
                  <%= new Date(ev.triggeredAt).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' }) %>
                </td>
                <td>
                  <a href="/p/<%= ev.productAsin %>" style="font-size:13px; font-weight:500">
                    <%= ev.productName ?? ev.productAsin %>
                  </a>
                  <span class="product-asin" style="display:block"><%= ev.productAsin %></span>
                </td>
                <td>
                  <span class="alert-badge badge-active" style="font-size:11px"><%= ev.alertType %></span>
                </td>
                <td class="price-cell"><%= parseFloat(ev.priceAtTime).toFixed(2) %> €</td>
                <td style="font-size:12px; color:var(--gray-500)"><%= ev.thresholdLabel ?? '—' %></td>
                <td style="font-size:12px; color:var(--gray-500)"><%= ev.userEmail %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <div style="margin-top:12px">
    <a href="/" class="hint-link">← Volver al dashboard</a>
  </div>

</main>

<%- include('partials/footer-admin') %>

<script src="/js/scrape-widget.js"></script>
</body>
</html>
