<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Iniciar sesión — OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">

<div class="auth-card">
  <div class="auth-logo">
    <span class="brand-icon-lg">👁</span>
    <h1>OjoAlPrecio</h1>
    <p>Seguimiento de precios en Amazon.es</p>
  </div>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert-box" style="background:var(--green-light,#f0fdf4); border:1px solid var(--green); color:#166534; margin-bottom:16px;"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert-box alert-error"><%= error %></div>
  <% } %>

  <form action="/auth/login" method="POST" class="auth-form">
    <div class="form-field">
      <label for="email">Email</label>
      <input
        type="email"
        name="email"
        id="email"
        value="<%= email %>"
        required
        autocomplete="email"
        class="input"
        placeholder="tu@email.com"
      >
    </div>
    <div class="form-field">
      <label for="password">Contraseña</label>
      <input
        type="password"
        name="password"
        id="password"
        required
        autocomplete="current-password"
        class="input"
        placeholder="••••••••"
      >
    </div>
    <button type="submit" class="btn btn-primary btn-full">Iniciar sesión</button>
  </form>

  <p class="auth-alt">
    ¿No tienes cuenta? <a href="/auth/register">Regístrate</a>
  </p>
</div>

</body>
</html>
