<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mejores ofertas en Amazon.es — OjoAlPrecio</title>
  <meta name="description" content="Ofertas y bajadas de precio en Amazon.es en tiempo real. Historial de precios y alertas gratuitas.">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar', { variant: 'deals', user: typeof user !== 'undefined' ? user : null, isAdmin: typeof isAdmin !== 'undefined' ? isAdmin : false }) %>

<main class="container-wide">

  <div class="page-header">
    <h1>Mejores ofertas</h1>
    <p class="subtitle">Productos en Amazon.es con bajadas de precio destacadas</p>
  </div>

  <%# Marketplace switcher — visible reciprocal link to the AE hot feed. -%>
  <div style="display:flex;gap:var(--sp-2);margin-bottom:var(--sp-4);flex-wrap:wrap">
    <span class="btn btn-sm btn-amazon" style="cursor:default">📦 Ofertas Amazon</span>
    <a href="/ofertas/aliexpress" class="btn btn-sm btn-outline">🛒 Chollos AliExpress</a>
  </div>

  <% const totalDeals = groups.reduce((s, g) => s + g.deals.length, 0); %>

  <% if (process.env.TELEGRAM_PUBLIC_CHANNEL) { %>
  <a href="https://t.me/<%= process.env.TELEGRAM_PUBLIC_CHANNEL.replace('@','') %>" target="_blank" rel="noopener"
     style="display:flex;align-items:center;gap:10px;background:#e8f4fd;border:1px solid #bee3f8;border-radius:10px;padding:12px 18px;margin-bottom:20px;text-decoration:none;color:#1a56db">
    <span style="font-size:22px">📢</span>
    <span style="font-size:14px"><strong>Recibe la oferta del día en Telegram</strong> — Únete al canal gratuito y no te pierdas ningún chollo</span>
    <span style="margin-left:auto;font-size:13px;white-space:nowrap;font-weight:600">Unirse →</span>
  </a>
  <% } %>

  <% if (totalDeals === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">🔍</div>
      <h3>Sin ofertas publicadas todavía</h3>
      <p>Cuando los usuarios compartan sus productos, aparecerán aquí.</p>
    </div>
  <% } else { %>

    <% if (groups.length > 1) { %>
    <nav class="category-nav">
      <button class="category-nav-link active" onclick="filterDeals(null, this)">Todas</button>
      <% groups.forEach(function(g) { %>
        <button class="category-nav-link" onclick="filterDeals('<%= g.slug ?? 'otros' %>', this)"><%= g.name %></button>
      <% }); %>
    </nav>
    <% } %>

    <% groups.forEach(function(group) { %>
      <section class="category-section" id="cat-<%= group.slug ?? 'otros' %>">
        <% if (groups.length > 1) { %>
          <h2 class="category-section-title"><%= group.name %></h2>
        <% } %>
        <div class="product-grid">
          <% group.deals.forEach(function(d) { %>
            <%- include('partials/deal-card', { d: d, showOfferFallback: true }) %>
          <% }); %>
        </div>
      </section>
    <% }); %>

  <% } %>

</main>

<%- include('partials/footer', { middleHtml: '<a href="/auth/login">Añade tus productos</a>' }) %>

<style>
.sparkline-svg { display: block; margin-top: 6px; }
.product-img-wrap[data-images] { cursor: pointer; }
</style>
<script>
function filterDeals(slug, btn) {
  document.querySelectorAll('.category-section').forEach(s => {
    s.style.display = (!slug || s.id === 'cat-' + slug) ? '' : 'none';
  });
  document.querySelectorAll('.category-nav-link').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

(function() {
  document.querySelectorAll('.product-img-wrap[data-images]').forEach(function(wrap) {
    const images = JSON.parse(wrap.dataset.images);
    if (images.length < 2) return;
    const img = wrap.querySelector('.product-img');
    if (!img) return;
    let idx = 0, timer = null;
    wrap.addEventListener('mouseenter', function() {
      timer = setInterval(function() {
        idx = (idx + 1) % images.length;
        img.src = images[idx];
      }, 2000);
    });
    wrap.addEventListener('mouseleave', function() {
      clearInterval(timer);
      timer = null;
      idx = 0;
      img.src = images[0];
    });
  });
})();
</script>
<%- include('partials/bottom-nav', { user: typeof user !== 'undefined' ? user : null, activeNav: 'ofertas' }) %>

</body>
</html>
