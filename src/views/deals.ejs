<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mejores ofertas en Amazon.es — OjoAlPrecio</title>
  <meta name="description" content="Ofertas y bajadas de precio en Amazon.es en tiempo real. Historial de precios y alertas gratuitas.">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/auth/login" class="btn btn-outline btn-sm">Entrar</a>
  </div>
</nav>

<main class="container-wide">

  <div class="page-header">
    <h1>Mejores ofertas</h1>
    <p class="subtitle">Productos en Amazon.es con bajadas de precio destacadas</p>
  </div>

  <% const totalDeals = groups.reduce((s, g) => s + g.deals.length, 0); %>

  <% if (totalDeals === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">🔍</div>
      <h3>Sin ofertas publicadas todavía</h3>
      <p>Cuando los usuarios compartan sus productos, aparecerán aquí.</p>
    </div>
  <% } else { %>

    <% if (groups.length > 1) { %>
    <nav class="category-nav">
      <button class="category-nav-link active" onclick="filterDeals(null, this)">Todas</button>
      <% groups.forEach(function(g) { %>
        <button class="category-nav-link" onclick="filterDeals('<%= g.slug ?? 'otros' %>', this)"><%= g.name %></button>
      <% }); %>
    </nav>
    <% } %>

    <% groups.forEach(function(group) { %>
      <section class="category-section" id="cat-<%= group.slug ?? 'otros' %>">
        <% if (groups.length > 1) { %>
          <h2 class="category-section-title"><%= group.name %></h2>
        <% } %>
        <div class="product-grid">
          <% group.deals.forEach(function(d) {
            const allImages = [d.imageUrl, ...d.extraImages].filter(Boolean).slice(0, 3);
            const hasCarousel = allImages.length > 1;
          %>
            <div class="product-card">
              <a href="/p/<%= d.asin %>" class="product-card-link">
                <div class="product-img-wrap"<% if (hasCarousel) { %> data-images="<%- JSON.stringify(allImages).replace(/"/g, '&quot;') %>"<% } %>>
                  <% if (d.imageUrl) { %>
                    <img src="<%= d.imageUrl %>" alt="<%= d.name ?? d.asin %>" class="product-img" loading="lazy">
                  <% } else { %>
                    <div class="product-img-placeholder">📦</div>
                  <% } %>
                  <% if (d.isAtLow) { %>
                    <span class="badge-low">Precio mínimo</span>
                  <% } else { %>
                    <span class="badge-sale">Oferta</span>
                  <% } %>
                </div>
                <div class="product-info">
                  <p class="product-name"><%= d.name ?? d.asin %></p>
                </div>
              </a>
              <div class="product-prices">
                <div class="price-row">
                  <div class="price-current"><%= parseFloat(d.currentPrice).toFixed(2) %> €</div>
                  <% if (d.discountFromMax > 0) { %>
                    <span class="trend-down">↓ <%= d.discountFromMax %>% vs max</span>
                  <% } %>
                </div>
                <% if (d.minPrice && d.maxPrice) { %>
                  <div class="price-range">
                    <span class="price-min">↓ <%= parseFloat(d.minPrice).toFixed(2) %> €</span>
                    <span class="price-max">↑ <%= parseFloat(d.maxPrice).toFixed(2) %> €</span>
                  </div>
                <% } %>
                <% if (d.sparkline && d.sparkline.length >= 2) {
                  const pts = [...d.sparkline].reverse();
                  const mn = Math.min(...pts), mx = Math.max(...pts), rng = mx - mn || 1;
                  const W = 120, H = 36, pad = 3;
                  const svgPts = pts.map(function(v, i) {
                    return (pad + (i / (pts.length - 1)) * (W - 2*pad)).toFixed(1) + ',' +
                           (H - pad - ((v - mn) / rng) * (H - 2*pad)).toFixed(1);
                  }).join(' ');
                  const color = pts[pts.length-1] < pts[0] ? '#22c55e' : pts[pts.length-1] > pts[0] ? '#ef4444' : '#94a3b8';
                %>
                <svg class="sparkline-svg" viewBox="0 0 <%= W %> <%= H %>" width="<%= W %>" height="<%= H %>" aria-hidden="true">
                  <polyline points="<%= svgPts %>" fill="none" stroke="<%= color %>" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <% } %>
              </div>
              <div class="product-actions">
                <a href="/p/<%= d.asin %>" class="btn btn-sm btn-outline">Ver historial</a>
                <a href="<%= d.amazonUrl %>" target="_blank" rel="noopener sponsored" class="btn btn-sm btn-primary">Amazon ↗</a>
              </div>
            </div>
          <% }); %>
        </div>
      </section>
    <% }); %>

  <% } %>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> &nbsp;·&nbsp; <a href="/auth/login">Añade tus productos</a></p>
</footer>

<style>
.sparkline-svg { display: block; margin-top: 6px; }
.product-img-wrap[data-images] { cursor: pointer; }
</style>
<script>
function filterDeals(slug, btn) {
  document.querySelectorAll('.category-section').forEach(s => {
    s.style.display = (!slug || s.id === 'cat-' + slug) ? '' : 'none';
  });
  document.querySelectorAll('.category-nav-link').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

(function() {
  document.querySelectorAll('.product-img-wrap[data-images]').forEach(function(wrap) {
    const images = JSON.parse(wrap.dataset.images);
    if (images.length < 2) return;
    const img = wrap.querySelector('.product-img');
    if (!img) return;
    let idx = 0, timer = null;
    wrap.addEventListener('mouseenter', function() {
      timer = setInterval(function() {
        idx = (idx + 1) % images.length;
        img.src = images[idx];
      }, 2000);
    });
    wrap.addEventListener('mouseleave', function() {
      clearInterval(timer);
      timer = null;
      idx = 0;
      img.src = images[0];
    });
  });
})();
</script>
</body>
</html>
