<%
const dayMap = {};
daily.forEach(function(r) { dayMap[r.day] = parseInt(r.views, 10); });
const days = [];
for (let i = 29; i >= 0; i--) {
  const d = new Date(); d.setDate(d.getDate() - i);
  const key = d.toISOString().slice(0, 10);
  days.push({ key, views: dayMap[key] ?? 0 });
}
const maxViews = Math.max(...days.map(d => d.views), 1);
const last30 = days.reduce((s, d) => s + d.views, 0);

const alertDayMap = {};
alertDaily.forEach(function(r) { alertDayMap[r.day] = parseInt(r.count, 10); });
const alertDays = days.map(function(d) { return { key: d.key, count: alertDayMap[d.key] ?? 0 }; });
const maxAlerts = Math.max(...alertDays.map(function(d) { return d.count; }), 1);
const totalAlerts = parseInt(alertTotals && alertTotals.total ? alertTotals.total : '0', 10);
%>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Estadísticas — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/admin/categories" class="nav-link">Categorías</a>
    <a href="/admin/deals" class="nav-link">Chollos</a>
    <a href="/admin/social" class="nav-link">Social</a>
    <a href="/admin/stats" class="nav-link nav-link-active">Stats</a>
    <a href="/admin/users" class="nav-link">Usuarios</a>
    <span id="scrape-widget" style="position:relative;margin-right:4px"></span>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<main class="container">

  <div class="page-header">
    <h1>Estadísticas de visitas</h1>
    <p class="subtitle">Páginas vistas en rutas públicas (excluye admin, auth y assets) &nbsp;·&nbsp; <a href="/admin/alerts" class="hint-link">Ver alertas →</a></p>
  </div>

  <div class="stats-bar" style="margin-bottom:24px">
    <div class="stat-pill">
      <span class="stat-pill-value"><%= parseInt(total, 10).toLocaleString('es-ES') %></span>
      <span class="stat-pill-label">visitas totales</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= last30.toLocaleString('es-ES') %></span>
      <span class="stat-pill-label">últimos 30 días</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= (last30 / 30).toFixed(0) %></span>
      <span class="stat-pill-label">media/día</span>
    </div>
  </div>

  <!-- Bar chart -->
  <div class="card" style="margin-bottom:16px">
    <h2>Visitas por día — últimos 30 días</h2>
    <div style="position:relative;margin-top:16px">
      <div style="font-size:11px;color:var(--gray-400);text-align:right;margin-bottom:2px">máx: <%= maxViews.toLocaleString('es-ES') %></div>
      <div style="display:flex;align-items:flex-end;gap:3px;height:80px;padding:0 2px">
        <% days.forEach(function(d) {
          const isToday = d.key === new Date().toISOString().slice(0, 10);
          const h = (d.views > 0 || isToday) ? Math.max(4, Math.round((d.views / maxViews) * 76)) : 0;
        %>
          <div class="chart-bar"
               data-date="<%= d.key %>" data-count="<%= d.views %>" data-label="visitas"
               style="flex:1;height:<%=h%>px;background:<%= isToday ? '#1d4ed8' : (d.views > 0 ? '#cbd5e1' : '#f1f5f9') %>;border-radius:2px 2px 0 0;min-width:4px;cursor:default;align-self:flex-end">
          </div>
        <% }); %>
      </div>
      <div style="display:flex;justify-content:space-between;margin-top:4px;font-size:11px;color:var(--gray-400)">
        <span><%= days[0].key.slice(5).replace('-', '/') %></span>
        <span>hoy</span>
      </div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">

    <!-- Top products -->
    <div class="card">
      <h2>Productos más vistos <span class="hint">(página pública /p/…)</span></h2>
      <% if (topProducts.length === 0) { %>
        <p class="hint" style="margin-top:12px">Sin datos todavía.</p>
      <% } else { %>
      <div class="table-wrap" style="margin-top:12px">
        <table class="price-table">
          <thead><tr><th>#</th><th>Producto</th><th style="text-align:right">Vistas</th></tr></thead>
          <tbody>
            <% topProducts.forEach(function(row, i) { %>
              <tr>
                <td style="color:var(--gray-400);width:28px"><%= i + 1 %></td>
                <td>
                  <a href="/p/<%= row.asin %>" class="hint-link" target="_blank" style="font-size:12px">
                    <%= row.name ? (row.name.length > 50 ? row.name.slice(0,50) + '…' : row.name) : row.asin %>
                  </a>
                </td>
                <td style="text-align:right;font-weight:600"><%= parseInt(row.views, 10).toLocaleString('es-ES') %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <!-- Top other paths -->
    <div class="card">
      <h2>Otras rutas más visitadas</h2>
      <% if (topPaths.length === 0) { %>
        <p class="hint" style="margin-top:12px">Sin datos todavía.</p>
      <% } else { %>
      <div class="table-wrap" style="margin-top:12px">
        <table class="price-table">
          <thead><tr><th>#</th><th>Ruta</th><th style="text-align:right">Vistas</th></tr></thead>
          <tbody>
            <% topPaths.forEach(function(row, i) { %>
              <tr>
                <td style="color:var(--gray-400);width:28px"><%= i + 1 %></td>
                <td><a href="<%= row.path %>" class="hint-link" target="_blank"><%= row.path %></a></td>
                <td style="text-align:right;font-weight:600"><%= parseInt(row.views, 10).toLocaleString('es-ES') %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </div>

  <!-- Traffic sources + devices -->
  <div class="page-header" style="margin-top:40px">
    <h1>Fuentes y dispositivos</h1>
    <p class="subtitle">Origen del tráfico y tipo de dispositivo. Las fuentes excluyen bots.</p>
  </div>

  <%
    const tsRows  = trafficSources || [];
    const devRows = devices || [];
    const tsTotal  = tsRows.reduce(function(s, r)  { return s + parseInt(r.views, 10); }, 0);
    const devTotal = devRows.reduce(function(s, r) { return s + parseInt(r.views, 10); }, 0);
  %>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">

    <!-- Sources table -->
    <div class="card">
      <h2>Fuentes de tráfico</h2>
      <% if (tsRows.length === 0) { %>
        <p class="hint" style="margin-top:12px">Sin datos todavía.</p>
      <% } else { %>
      <div class="table-wrap" style="margin-top:12px">
        <table class="price-table">
          <thead><tr><th>#</th><th>Fuente</th><th style="text-align:right">Visitas</th><th style="text-align:right">%</th></tr></thead>
          <tbody>
            <% tsRows.forEach(function(r, i) {
              const v   = parseInt(r.views, 10);
              const pct = tsTotal > 0 ? ((v / tsTotal) * 100).toFixed(1) : '0.0';
            %>
              <tr>
                <td style="color:var(--gray-400);width:24px"><%= i + 1 %></td>
                <td style="font-weight:500"><%= r.source %></td>
                <td style="text-align:right;font-weight:600"><%= v.toLocaleString('es-ES') %></td>
                <td style="text-align:right;color:var(--gray-400)"><%= pct %>%</td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <!-- Devices table -->
    <div class="card">
      <h2>Dispositivos</h2>
      <% if (devRows.length === 0) { %>
        <p class="hint" style="margin-top:12px">Sin datos todavía.</p>
      <% } else { %>
      <div class="table-wrap" style="margin-top:12px">
        <table class="price-table">
          <thead><tr><th>#</th><th>Dispositivo</th><th style="text-align:right">Visitas</th><th style="text-align:right">%</th></tr></thead>
          <tbody>
            <% devRows.forEach(function(r, i) {
              const v   = parseInt(r.views, 10);
              const pct = devTotal > 0 ? ((v / devTotal) * 100).toFixed(1) : '0.0';
              const icon = r.device_type === 'Móvil' ? '📱' : r.device_type === 'Tablet' ? '📟' : r.device_type === 'Bot' ? '🤖' : '🖥';
            %>
              <tr>
                <td style="color:var(--gray-400);width:24px"><%= i + 1 %></td>
                <td style="font-weight:500"><%= icon %> <%= r.device_type %></td>
                <td style="text-align:right;font-weight:600"><%= v.toLocaleString('es-ES') %></td>
                <td style="text-align:right;color:var(--gray-400)"><%= pct %>%</td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </div>

  <!-- Alert stats -->
  <div class="page-header" style="margin-top:40px">
    <h1>Estadísticas de alertas</h1>
    <p class="subtitle">Alertas disparadas y enviadas.</p>
  </div>

  <div class="stats-bar" style="margin-bottom:24px">
    <div class="stat-pill">
      <span class="stat-pill-value"><%= totalAlerts.toLocaleString('es-ES') %></span>
      <span class="stat-pill-label">alertas totales</span>
    </div>
    <% if (alertTotals) { %>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= parseInt(alertTotals.by_email || '0', 10).toLocaleString('es-ES') %></span>
      <span class="stat-pill-label">por email</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= parseInt(alertTotals.by_telegram || '0', 10).toLocaleString('es-ES') %></span>
      <span class="stat-pill-label">por Telegram</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= parseInt(alertTotals.by_both || '0', 10).toLocaleString('es-ES') %></span>
      <span class="stat-pill-label">email + Telegram</span>
    </div>
    <% } %>
  </div>

  <!-- Alert bar chart -->
  <div class="card" style="margin-bottom:16px">
    <h2>Alertas disparadas — últimos 30 días</h2>
    <% if (totalAlerts === 0) { %>
      <p class="hint" style="margin-top:12px">Sin alertas disparadas todavía.</p>
    <% } else { %>
    <div style="position:relative;margin-top:16px">
      <div style="font-size:11px;color:var(--gray-400);text-align:right;margin-bottom:2px">máx: <%= maxAlerts.toLocaleString('es-ES') %></div>
      <div style="display:flex;align-items:flex-end;gap:3px;height:80px;padding:0 2px">
        <% alertDays.forEach(function(d) {
          const isToday = d.key === new Date().toISOString().slice(0, 10);
          const h = (d.count > 0 || isToday) ? Math.max(4, Math.round((d.count / maxAlerts) * 76)) : 0;
        %>
          <div class="chart-bar"
               data-date="<%= d.key %>" data-count="<%= d.count %>" data-label="alertas"
               style="flex:1;height:<%=h%>px;background:<%= isToday ? '#e63946' : (d.count > 0 ? '#fca5a5' : '#f1f5f9') %>;border-radius:2px 2px 0 0;min-width:4px;cursor:default;align-self:flex-end">
          </div>
        <% }); %>
      </div>
      <div style="display:flex;justify-content:space-between;margin-top:4px;font-size:11px;color:var(--gray-400)">
        <span><%= alertDays[0].key.slice(5).replace('-', '/') %></span><span>hoy</span>
      </div>
    </div>
    <% } %>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">

    <!-- Top products by alerts -->
    <div class="card">
      <h2>Productos con más alertas</h2>
      <% if (alertByProduct.length === 0) { %>
        <p class="hint" style="margin-top:12px">Sin datos todavía.</p>
      <% } else { %>
      <div class="table-wrap" style="margin-top:12px">
        <table class="price-table">
          <thead><tr><th>#</th><th>Producto</th><th style="text-align:right">Alertas</th></tr></thead>
          <tbody>
            <% alertByProduct.forEach(function(row, i) { %>
              <tr>
                <td style="color:var(--gray-400);width:28px"><%= i + 1 %></td>
                <td>
                  <a href="/products/<%= row.product_id %>" class="hint-link" style="font-size:12px">
                    <%= row.name ? (row.name.length > 45 ? row.name.slice(0,45) + '…' : row.name) : row.asin %>
                  </a>
                </td>
                <td style="text-align:right;font-weight:600"><%= parseInt(row.alert_count, 10).toLocaleString('es-ES') %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <!-- Top users by alerts -->
    <div class="card">
      <h2>Usuarios con más alertas recibidas</h2>
      <% if (alertByUser.length === 0) { %>
        <p class="hint" style="margin-top:12px">Sin datos todavía.</p>
      <% } else { %>
      <div class="table-wrap" style="margin-top:12px">
        <table class="price-table">
          <thead><tr><th>#</th><th>Usuario</th><th style="text-align:right">Alertas</th></tr></thead>
          <tbody>
            <% alertByUser.forEach(function(row, i) { %>
              <tr>
                <td style="color:var(--gray-400);width:28px"><%= i + 1 %></td>
                <td style="font-size:12px"><%= row.email %></td>
                <td style="text-align:right;font-weight:600"><%= parseInt(row.alert_count, 10).toLocaleString('es-ES') %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </div>

  <div style="margin-top:12px">
    <a href="/" class="hint-link">← Volver al dashboard</a>
  </div>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> Admin &nbsp;·&nbsp; <a href="/ofertas">Ver ofertas públicas</a></p>
</footer>

<div id="chart-tooltip" style="display:none;position:fixed;background:#111827;color:#fff;padding:5px 10px;border-radius:6px;font-size:12px;pointer-events:none;z-index:1000;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,.3)"></div>

<script src="/js/scrape-widget.js"></script>
<script>
(function () {
  const tooltip = document.getElementById('chart-tooltip');
  const months = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];

  function fmtDate(iso) {
    const parts = iso.split('-');
    return parseInt(parts[2], 10) + ' ' + months[parseInt(parts[1], 10) - 1] + ' ' + parts[0];
  }

  document.querySelectorAll('.chart-bar').forEach(function (bar) {
    bar.addEventListener('mouseover', function () {
      const count = parseInt(bar.dataset.count, 10).toLocaleString('es-ES');
      tooltip.textContent = fmtDate(bar.dataset.date) + ': ' + count + ' ' + (bar.dataset.label || '');
      tooltip.style.display = 'block';
    });
    bar.addEventListener('mousemove', function (e) {
      tooltip.style.left = (e.clientX + 14) + 'px';
      tooltip.style.top  = (e.clientY - 36) + 'px';
    });
    bar.addEventListener('mouseout', function () {
      tooltip.style.display = 'none';
    });
  });
})();
</script>
</body>
</html>
