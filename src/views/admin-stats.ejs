<%
// Build a map of day → views for the last 30 days
const dayMap = {};
daily.forEach(function(r) { dayMap[r.day] = parseInt(r.views, 10); });
const days = [];
for (let i = 29; i >= 0; i--) {
  const d = new Date(); d.setDate(d.getDate() - i);
  const key = d.toISOString().slice(0, 10);
  days.push({ key, views: dayMap[key] ?? 0 });
}
const maxViews = Math.max(...days.map(d => d.views), 1);
%>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Estadísticas — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/admin/categories" class="nav-link">Categorías</a>
    <a href="/admin/lists" class="nav-link">Listas</a>
    <a href="/admin/stats" class="nav-link nav-link-active">Stats</a>
    <a href="/admin/alerts" class="nav-link">Alertas</a>
    <a href="/admin/import-url" class="nav-link">Importar URL</a>
    <span class="user-email"><%= user.email %></span>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<main class="container">

  <div class="page-header">
    <h1>Estadísticas de visitas</h1>
    <p class="subtitle">Páginas vistas (excluye admin, auth y assets estáticos)</p>
  </div>

  <div class="stats-bar" style="margin-bottom:24px">
    <div class="stat-pill">
      <span class="stat-pill-value"><%= total.toLocaleString('es-ES') %></span>
      <span class="stat-pill-label">visitas totales</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= days.reduce((s, d) => s + d.views, 0).toLocaleString('es-ES') %></span>
      <span class="stat-pill-label">últimos 30 días</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= (days.reduce((s, d) => s + d.views, 0) / 30).toFixed(0) %></span>
      <span class="stat-pill-label">media/día</span>
    </div>
  </div>

  <!-- Bar chart: last 30 days -->
  <div class="card" style="margin-bottom:16px">
    <h2>Visitas por día — últimos 30 días</h2>
    <div style="display:flex;align-items:flex-end;gap:3px;height:100px;margin-top:16px;padding:0 4px">
      <% days.forEach(function(d) {
        const h = Math.max(2, Math.round((d.views / maxViews) * 90));
        const isToday = d.key === new Date().toISOString().slice(0, 10);
      %>
        <div title="<%= d.key %>: <%= d.views %> visitas"
             style="flex:1;height:<%=h%>px;background:<%= isToday ? 'var(--primary)' : '#cbd5e1' %>;border-radius:2px 2px 0 0;min-width:4px;cursor:default">
        </div>
      <% }); %>
    </div>
    <div style="display:flex;justify-content:space-between;margin-top:4px;font-size:11px;color:var(--gray-400)">
      <span><%= days[0].key %></span>
      <span>hoy</span>
    </div>
  </div>

  <!-- Top pages -->
  <div class="card">
    <h2>Páginas más vistas</h2>
    <div class="table-wrap" style="margin-top:16px">
      <table class="price-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Ruta</th>
            <th style="text-align:right">Visitas</th>
          </tr>
        </thead>
        <tbody>
          <% top.forEach(function(row, i) { %>
            <tr>
              <td style="color:var(--gray-400);width:32px"><%= i + 1 %></td>
              <td>
                <a href="<%= row.path %>" class="hint-link" target="_blank"><%= row.path %></a>
              </td>
              <td style="text-align:right"><%= parseInt(row.views, 10).toLocaleString('es-ES') %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div style="margin-top:12px">
    <a href="/" class="hint-link">← Volver al dashboard</a>
  </div>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> Admin &nbsp;·&nbsp; <a href="/ofertas">Ver ofertas públicas</a></p>
</footer>

</body>
</html>
