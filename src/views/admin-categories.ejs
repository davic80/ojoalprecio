<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Categorías — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
</head>
<body>

<%- include('partials/navbar-admin', { user, activePage: 'categories' }) %>

<main class="container">

  <div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px">
    <div>
      <h1>Gestión de categorías</h1>
      <p class="subtitle">Las categorías que crees aquí estarán disponibles para todos los usuarios.</p>
    </div>
    <a href="/admin/lists" class="btn btn-sm btn-outline" style="margin-top:6px">Listas de recomendación →</a>
  </div>

  <!-- Add category -->
  <div class="card add-card">
    <h2>Nueva categoría</h2>
    <form action="/admin/categories" method="POST" class="add-form">
      <div class="input-group">
        <input type="text" name="name" placeholder="Nombre de la categoría" required
          class="input" autocomplete="off" maxlength="100">
        <button type="submit" class="btn btn-primary">Crear</button>
      </div>
      <p class="hint">El slug se genera automáticamente. Ejemplo: "Audio y sonido" → audio-y-sonido</p>
    </form>
  </div>

  <!-- Category list -->
  <div class="card">
    <h2>Categorías existentes (<%= categories.length %>)</h2>
    <% if (categories.length === 0) { %>
      <p class="hint" style="margin-top:12px">No hay categorías todavía. Crea la primera arriba.</p>
    <% } else { %>
      <div class="table-wrap" style="margin-top:16px">
        <table class="price-table">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Slug</th>
              <th style="text-align:right">Total</th>
              <th style="text-align:right">Oferta</th>
              <th style="text-align:right">Públicos</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <a href="/?category=none&status=all&sort=recent&per_page=20" class="category-link-admin" style="color:var(--gray-500);font-style:italic">Sin categoría</a>
                <span style="font-size:11px;color:var(--gray-400)"> (dashboard)</span>
              </td>
              <td><code class="hint">—</code></td>
              <td style="text-align:right"><%= uncategorizedCount %></td>
              <td style="text-align:right"><%= uncategorizedSaleCount > 0 ? uncategorizedSaleCount : '—' %></td>
              <td style="text-align:right"><%= uncategorizedPublicCount > 0 ? uncategorizedPublicCount : '—' %></td>
              <td></td>
            </tr>
            <% categories.forEach(function(cat) { %>
              <tr id="cat-<%= cat.id %>">
                <td>
                  <a href="/?category=<%= cat.id %>&status=all&sort=recent&per_page=50" class="category-link-admin"><strong><%= cat.name %></strong></a>
                </td>
                <td><code class="hint"><%= cat.slug %></code></td>
                <td style="text-align:right"><%= cat.productCount %></td>
                <td style="text-align:right"><%= parseInt(cat.saleCount) > 0 ? parseInt(cat.saleCount) : '—' %></td>
                <td style="text-align:right"><%= parseInt(cat.publicCount) > 0 ? parseInt(cat.publicCount) : '—' %></td>
                <td style="text-align:right">
                  <button
                    class="btn btn-sm btn-danger"
                    hx-delete="/admin/categories/<%= cat.id %>"
                    hx-target="#cat-<%= cat.id %>"
                    hx-swap="outerHTML"
                    hx-confirm="¿Eliminar '<%= cat.name %>'? Los productos quedarán sin categoría."
                  >Eliminar</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <div style="margin-top:12px">
    <a href="/" class="hint-link">← Volver al dashboard</a>
  </div>

</main>

<%- include('partials/footer-admin') %>

<script src="/js/scrape-widget.js"></script>
</body>
</html>
