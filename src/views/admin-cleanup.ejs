<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Limpieza — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/navbar-admin', { user, activePage: 'cleanup' }) %>

<main class="container-wide">

  <div class="page-header">
    <h1>Limpieza · candidatos a borrar</h1>
    <p class="subtitle">
      Productos auto-importados (sin <code>created_by_user_id</code> de usuario humano),
      <strong>sin seguidores reales</strong> y <strong>sin alertas</strong>, que llevan
      <strong>≥3 días</strong> en el catálogo y han tenido <strong>&lt; 3 datapoints en
      los últimos 3 días</strong>. Cálculo on-demand sobre la BD, siempre fresco.
      <strong>Siguen scrapeándose</strong> en cada ciclo de 1h hasta que los borres o pauses.
    </p>
  </div>

  <% if (candidates.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">✨</div>
      <h3>Nada que borrar</h3>
      <p>No hay productos auto-importados huérfanos con scrape moribundo en este momento.</p>
    </div>
  <% } else { %>
    <div class="bulk-bar" data-admin-bulk-bar-for="cleanup-table">
      <span data-bulk-count></span>
      <button type="button" data-bulk-action="pause" class="btn btn-sm btn-outline" title="Pone is_active=FALSE: deja de scrapearse pero se conservan datos">
        ⏸ Pausar scrape
      </button>
      <button type="button" data-bulk-action="delete" class="btn btn-sm btn-danger" title="Borrado definitivo — cascadea a price_history, alerts, user_products, anomalías">
        🗑 Borrar
      </button>
      <span id="bulk-result" class="hint" style="color:var(--green)"></span>
      <span class="hint" style="margin-left:auto"><%= candidates.length %> candidato<%= candidates.length === 1 ? '' : 's' %><% if (candidates.length >= 500) { %> (mostrando los primeros 500)<% } %></span>
    </div>

    <div class="table-wrap">
      <table id="cleanup-table" data-admin-table class="price-table table-card-mobile">
        <thead>
          <tr>
            <th class="select-col"><input type="checkbox" data-select-all aria-label="Seleccionar todos"></th>
            <th data-col="name" class="sortable-col">Producto</th>
            <th data-col="daysOld" class="sortable-col" style="text-align:right">Días en BD</th>
            <th data-col="datapoints3d" class="sortable-col" data-default-sort="asc" style="text-align:right">Datapoints 3d</th>
            <th data-col="datapointsTotal" class="sortable-col" style="text-align:right">Total datapoints</th>
            <th data-col="lastScrapeAt" class="sortable-col" style="text-align:right">Último scrape</th>
            <th data-col="state" class="sortable-col">Estado</th>
          </tr>
        </thead>
        <tbody>
          <% candidates.forEach(function(p) {
            const lastScrapeMs = p.lastScrapeAt ? new Date(p.lastScrapeAt).getTime() : 0;
            const state = !p.isAvailable ? 'sinstock' : (p.lastError ? 'error' : 'ok');
          %>
            <tr
              data-name="<%- (p.name ?? p.asin).replace(/"/g,'&quot;') %>"
              data-days-old="<%= p.daysOld %>"
              data-datapoints3d="<%= p.datapoints3d %>"
              data-datapoints-total="<%= p.datapointsTotal %>"
              data-last-scrape-at="<%= lastScrapeMs %>"
              data-state="<%= state %>"
            >
              <td><input type="checkbox" class="row-select" value="<%= p.id %>" aria-label="Seleccionar <%= p.asin %>"></td>
              <td data-label="Producto" style="max-width:380px">
                <a href="/p/<%= p.asin %>" target="_blank" rel="noopener" style="font-size:13px;font-weight:500">
                  <%= p.name ? (p.name.length > 70 ? p.name.slice(0, 70) + '…' : p.name) : p.asin %>
                </a>
                <div class="hint" style="font-size:11px;margin-top:2px">
                  <code><%= p.asin %></code>
                </div>
              </td>
              <td data-label="Días" style="text-align:right;font-variant-numeric:tabular-nums"><%= p.daysOld %></td>
              <td data-label="Datapoints 3d" style="text-align:right;font-variant-numeric:tabular-nums;color:<%= p.datapoints3d === 0 ? 'var(--red)' : 'var(--gray-700)' %>">
                <%= p.datapoints3d %>
              </td>
              <td data-label="Total datapoints" style="text-align:right;font-variant-numeric:tabular-nums"><%= p.datapointsTotal %></td>
              <td data-label="Último scrape" style="text-align:right;font-size:12px;color:var(--gray-500)">
                <%= p.lastScrapeAt ? new Date(p.lastScrapeAt).toLocaleString('es-ES') : '—' %>
              </td>
              <td data-label="Estado">
                <% if (!p.isAvailable) { %>
                  <span class="alert-badge badge-triggered">Sin stock</span>
                <% } else if (p.lastError) { %>
                  <span class="alert-badge" style="background:var(--red-light);color:#9b1c1c" title="<%= p.lastError %>">Error</span>
                <% } else { %>
                  <span class="hint">—</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>

</main>

<%- include('partials/footer-admin') %>

<script src="/js/admin-table.js"></script>
<script>
(function () {
  const table = document.getElementById('cleanup-table');
  if (!table) return;

  function selectedIds() {
    return [...window.AdminTable.get(table).selected].map(Number);
  }

  async function bulkAction(action) {
    const ids = selectedIds();
    if (!ids.length) return;
    const verb = action === 'pause' ? 'pausar' : 'borrar';
    if (!confirm(`¿${verb.charAt(0).toUpperCase() + verb.slice(1)} ${ids.length} producto(s)?` +
      (action === 'delete' ? ' Se eliminan también su historial de precios, alertas, follows y anomalías. Esta acción no se puede deshacer.' : ' Quedan en BD pero el scraper deja de procesarlos.'))) return;
    const url = action === 'delete' ? '/products/bulk-delete' : '/admin/products/bulk-pause';
    const result = document.getElementById('bulk-result');
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        alert('Error: ' + (err.error || res.statusText));
        return;
      }
      const data = await res.json();
      const n = data.deleted ?? data.paused ?? ids.length;
      result.textContent = `✓ ${n} ${action === 'delete' ? 'borrado' : 'pausado'}${n === 1 ? '' : 's'}`;
      setTimeout(() => location.reload(), 800);
    } catch (e) {
      alert('Error de red');
    }
  }

  table.parentElement.parentElement.querySelectorAll('[data-bulk-action]').forEach(function (btn) {
    btn.addEventListener('click', function () { bulkAction(btn.dataset.bulkAction); });
  });
})();
</script>

</body>
</html>
