<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Listas de recomendación — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/admin/categories" class="nav-link">Categorías</a>
    <a href="/admin/deals" class="nav-link">Chollos</a>
    <a href="/admin/social" class="nav-link">Social</a>
    <a href="/admin/stats" class="nav-link">Stats</a>
    <a href="/admin/users" class="nav-link">Usuarios</a>
    <span id="scrape-widget" style="position:relative;margin-right:4px"></span>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<main class="container">

  <div class="page-header">
    <h1>Listas de recomendación</h1>
    <p class="subtitle">Comparte listas de productos con una URL limpia: dominio.com/alberto</p>
  </div>

  <!-- Create list -->
  <div class="card add-card">
    <h2>Nueva lista</h2>
    <form action="/admin/lists" method="POST" class="add-form">
      <div class="input-group">
        <input type="text" name="name" placeholder="Nombre de la lista (ej: Alberto)" required
          class="input" autocomplete="off" maxlength="200">
        <button type="submit" class="btn btn-primary">Crear</button>
      </div>
      <input type="text" name="description" placeholder="Descripción opcional" class="input" style="margin-top:8px" maxlength="500">
      <p class="hint">El slug se genera del nombre. Ejemplo: "Para Alberto" → para-alberto → dominio.com/para-alberto</p>
    </form>
  </div>

  <!-- Lists table -->
  <div class="card">
    <h2>Listas existentes (<%= lists.length %>)</h2>
    <% if (lists.length === 0) { %>
      <p class="hint" style="margin-top:12px">No hay listas todavía. Crea la primera arriba.</p>
    <% } else { %>
      <div class="table-wrap" style="margin-top:16px">
        <table class="price-table">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>URL</th>
              <th style="text-align:right">Productos</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% lists.forEach(function(lst) { %>
              <tr id="list-<%= lst.id %>">
                <td>
                  <a href="/admin/lists/<%= lst.id %>" class="category-link-admin"><strong><%= lst.name %></strong></a>
                  <% if (lst.description) { %><br><span class="hint"><%= lst.description %></span><% } %>
                </td>
                <td>
                  <a href="/<%= lst.slug %>" class="hint" target="_blank">/<%= lst.slug %></a>
                </td>
                <td style="text-align:right"><%= lst.itemCount %></td>
                <td style="text-align:right">
                  <a href="/admin/lists/<%= lst.id %>" class="btn btn-sm btn-outline" style="margin-right:4px">Editar</a>
                  <button
                    class="btn btn-sm btn-danger"
                    hx-delete="/admin/lists/<%= lst.id %>"
                    hx-target="#list-<%= lst.id %>"
                    hx-swap="outerHTML"
                    hx-confirm="¿Eliminar la lista '<%= lst.name %>'?"
                  >Eliminar</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <div style="margin-top:12px">
    <a href="/" class="hint-link">← Volver al dashboard</a>
  </div>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> Admin &nbsp;·&nbsp; <a href="/ofertas">Ver ofertas públicas</a></p>
</footer>

<script src="/js/scrape-widget.js"></script>
</body>
</html>
