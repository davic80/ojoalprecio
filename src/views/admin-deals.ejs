<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mejores chollos — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/admin/categories" class="nav-link">Categorías</a>
    <a href="/admin/deals" class="nav-link nav-link-active">Chollos</a>
    <a href="/admin/social" class="nav-link">Social</a>
    <a href="/admin/stats" class="nav-link">Stats</a>
    <a href="/admin/users" class="nav-link">Usuarios</a>
    <span id="scrape-widget" style="position:relative;margin-right:4px"></span>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<main class="container">

  <div class="page-header">
    <h1>Mejores chollos</h1>
    <p class="subtitle">Productos en o cerca de su mínimo histórico, ordenados por bajada vs mediana de los últimos 30 días. Mínimo 20 registros.</p>
  </div>

  <!-- Filtros -->
  <form method="get" action="/admin/deals" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:20px">
    <select name="category" class="form-input" style="width:auto;min-width:160px;font-size:13px" onchange="this.form.submit()">
      <option value="">Todas las categorías</option>
      <% categories.forEach(function(cat) { %>
        <option value="<%= cat.id %>" <%= filters.category === cat.id ? 'selected' : '' %>><%= cat.name %></option>
      <% }); %>
    </select>
    <select name="pub" class="form-input" style="width:auto;min-width:130px;font-size:13px" onchange="this.form.submit()">
      <option value="">Público/Privado</option>
      <option value="1" <%= filters.pub === '1' ? 'selected' : '' %>>Solo públicos</option>
      <option value="0" <%= filters.pub === '0' ? 'selected' : '' %>>Solo privados</option>
    </select>
    <label style="display:flex;align-items:center;gap:6px;font-size:13px;cursor:pointer">
      <input type="checkbox" name="atmin" value="1" <%= filters.atmin ? 'checked' : '' %> onchange="this.form.submit()">
      Solo mínimo histórico
    </label>
    <% if (filters.category || filters.pub || filters.atmin) { %>
      <a href="/admin/deals" class="btn btn-sm btn-ghost" style="font-size:12px">✕ Limpiar filtros</a>
    <% } %>
    <span style="margin-left:auto;font-size:12px;color:var(--gray-400)"><%= deals.length %> productos</span>
  </form>

  <% if (deals.length === 0) { %>
    <div class="card">
      <p class="hint" style="margin:0">No hay productos que cumplan los criterios ahora mismo. Vuelve cuando haya más historial de precios.</p>
    </div>
  <% } else { %>
  <div class="table-wrap">
    <table class="price-table">
      <thead>
        <tr>
          <th style="width:48px"></th>
          <th data-col="name" class="sortable-col">Producto</th>
          <th data-col="currentPrice" class="sortable-col" style="text-align:right">Actual</th>
          <th data-col="minPrice" class="sortable-col" style="text-align:right">Mínimo</th>
          <th data-col="medianPrice" class="sortable-col" style="text-align:right">Mediana 30d</th>
          <th data-col="pctOffMedian" class="sortable-col sort-active sort-desc" style="text-align:right">vs mediana</th>
          <th data-col="pctOffMin" class="sortable-col" style="text-align:right">vs mínimo</th>
          <th style="text-align:center">Público</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% deals.forEach(function(d) {
          const pctMedian = parseFloat(d.pctOffMedian);
          const pctMin    = parseFloat(d.pctOffMin);
          const atMin     = Math.abs(pctMin) < 0.5;
        %>
        <tr
          data-name="<%- (d.name ?? d.asin).replace(/"/g,'&quot;') %>"
          data-current-price="<%= parseFloat(d.currentPrice) %>"
          data-min-price="<%= parseFloat(d.minPrice) %>"
          data-median-price="<%= parseFloat(d.medianPrice) %>"
          data-pct-off-median="<%= pctMedian %>"
          data-pct-off-min="<%= pctMin %>"
        >
          <td>
            <% if (d.imageUrl) { %>
              <img src="<%= d.imageUrl %>" alt="" style="width:40px;height:40px;object-fit:contain;border-radius:4px;">
            <% } %>
          </td>
          <td style="max-width:280px">
            <a href="/products/<%= d.id %>" class="hint-link" style="font-size:13px;font-weight:500;">
              <%= d.name ? (d.name.length > 70 ? d.name.slice(0,70) + '…' : d.name) : d.asin %>
            </a>
            <% if (atMin) { %>
              <span class="badge badge-sale" style="margin-left:6px;font-size:10px;vertical-align:middle;">Mínimo histórico</span>
            <% } %>
          </td>
          <td style="text-align:right;font-weight:700;color:#e63946;white-space:nowrap">
            <%= parseFloat(d.currentPrice).toFixed(2) %> €
          </td>
          <td style="text-align:right;color:var(--gray-500);font-size:13px;white-space:nowrap">
            <%= parseFloat(d.minPrice).toFixed(2) %> €
          </td>
          <td style="text-align:right;color:var(--gray-500);font-size:13px;white-space:nowrap">
            <%= parseFloat(d.medianPrice).toFixed(2) %> €
          </td>
          <td style="text-align:right;white-space:nowrap">
            <% if (pctMedian > 0) { %>
              <span style="color:#16a34a;font-weight:600;">−<%= pctMedian.toFixed(1) %>%</span>
            <% } else { %>
              <span style="color:var(--gray-400);font-size:13px;"><%= pctMedian.toFixed(1) %>%</span>
            <% } %>
          </td>
          <td style="text-align:right;white-space:nowrap">
            <% if (atMin) { %>
              <span style="color:#e63946;font-weight:600;">0%</span>
            <% } else { %>
              <span style="color:var(--gray-400);font-size:13px;">+<%= Math.abs(pctMin).toFixed(1) %>%</span>
            <% } %>
          </td>
          <td style="text-align:center;white-space:nowrap">
            <button
              class="btn btn-sm public-toggle"
              data-id="<%= d.id %>"
              data-public="<%= d.isPublic ? '1' : '0' %>"
              style="font-size:12px;<%= d.isPublic ? 'background:#16a34a;color:#fff;border-color:#16a34a' : '' %>"
            ><%= d.isPublic ? 'Público' : 'Privado' %></button>
          </td>
          <td style="white-space:nowrap">
            <a href="<%= d.url %>?tag=canidrone-21" target="_blank" rel="noopener" class="btn btn-sm btn-ghost" style="font-size:12px">Amazon ↗</a>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <p class="hint" style="margin-top:12px">
    Se muestran hasta 100 productos con bajada ≥ 5% vs mediana 30d y al menos 10 registros.
  </p>
  <% } %>

  <div style="margin-top:16px">
    <a href="/" class="hint-link">← Volver al dashboard</a>
  </div>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> Admin &nbsp;·&nbsp; <a href="/ofertas">Ver ofertas públicas</a></p>
</footer>

<style>
.sortable-col { cursor:pointer; user-select:none; white-space:nowrap; }
.sortable-col::after { content:' ⇅'; opacity:0.3; font-size:11px; }
.sortable-col.sort-asc::after  { content:' ↑'; opacity:1; }
.sortable-col.sort-desc::after { content:' ↓'; opacity:1; }
</style>
<script>
(function() {
  const tbody = document.querySelector('.price-table tbody');
  const headers = document.querySelectorAll('.sortable-col');
  // map th data-col value → row dataset key (camelCase from kebab HTML attr)
  const colToDataKey = {
    name:         'name',
    currentPrice: 'currentPrice',
    minPrice:     'minPrice',
    medianPrice:  'medianPrice',
    pctOffMedian: 'pctOffMedian',
    pctOffMin:    'pctOffMin',
  };
  let sortCol = 'pctOffMedian', sortDir = -1;

  function applySort() {
    const key = colToDataKey[sortCol];
    const rows = Array.from(tbody.querySelectorAll('tr'));
    rows.sort(function(a, b) {
      if (sortCol === 'name') {
        return sortDir * (a.dataset[key] ?? '').localeCompare(b.dataset[key] ?? '');
      }
      return sortDir * (parseFloat(a.dataset[key] ?? '0') - parseFloat(b.dataset[key] ?? '0'));
    });
    rows.forEach(function(r) { tbody.appendChild(r); });
    headers.forEach(function(h) {
      h.classList.remove('sort-asc', 'sort-desc');
      if (h.dataset.col === sortCol) h.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');
    });
  }

  headers.forEach(function(h) {
    h.addEventListener('click', function() {
      const col = h.dataset.col;
      sortDir = (sortCol === col) ? sortDir * -1 : (col === 'name' ? 1 : -1);
      sortCol = col;
      applySort();
    });
  });
})();

document.querySelectorAll('.public-toggle').forEach(function(btn) {
  btn.addEventListener('click', async function() {
    const id = btn.dataset.id;
    btn.disabled = true;
    try {
      const res = await fetch('/products/' + id + '/toggle-public', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      const data = await res.json();
      btn.dataset.public = data.isPublic ? '1' : '0';
      btn.textContent = data.isPublic ? 'Público' : 'Privado';
      btn.style.background = data.isPublic ? '#16a34a' : '';
      btn.style.color = data.isPublic ? '#fff' : '';
      btn.style.borderColor = data.isPublic ? '#16a34a' : '';
    } catch(e) { console.error(e); }
    btn.disabled = false;
  });
});
</script>
<script src="/js/scrape-widget.js"></script>
</body>
</html>
