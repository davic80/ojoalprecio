<%
function sparklineSvg(data, w, h) {
  if (!data || data.length < 2) return '';
  const nums = data.map(p => parseFloat(p));
  const min = Math.min(...nums);
  const max = Math.max(...nums);
  const range = max - min || 1;
  const pad = 2;
  const pts = nums.map((p, i) => {
    const x = pad + (i / (nums.length - 1)) * (w - pad * 2);
    const y = pad + (1 - (p - min) / range) * (h - pad * 2);
    return x.toFixed(1) + ',' + y.toFixed(1);
  }).join(' ');
  const trend = nums[nums.length - 1] <= nums[0] ? '#2a9d8f' : '#e63946';
  return `<svg viewBox="0 0 ${w} ${h}" preserveAspectRatio="none" class="sparkline" aria-hidden="true"><polyline points="${pts}" fill="none" stroke="${trend}" stroke-width="1.5" stroke-linejoin="round"/></svg>`;
}

function trendBadge(current, previous) {
  if (!current || !previous) return '';
  const cur = parseFloat(current);
  const prev = parseFloat(previous);
  if (prev === 0) return '';
  const diff = cur - prev;
  const pct = (diff / prev * 100);
  if (Math.abs(pct) < 0.1) return '<span class="trend-neutral">—</span>';
  const absPct = Math.abs(pct).toFixed(1);
  const absDiff = Math.abs(diff).toFixed(2);
  if (diff < 0) return `<span class="trend-down">↓ ${absPct}% · −${absDiff} €</span>`;
  return `<span class="trend-up">↑ ${absPct}% · +${absDiff} €</span>`;
}
%>
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mis productos — OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js" defer></script>
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/ofertas" class="nav-link">Ofertas</a>
    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
      <a href="/admin/categories" class="nav-link">Admin</a>
    <% } %>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<main class="container">

  <div class="page-header">
    <h1>Mis productos</h1>
    <p class="subtitle">Sigue el precio de tus artículos favoritos de Amazon.es</p>
  </div>

  <% if (stats.total > 0) { %>
  <%
    const activeStatus = filters.status || 'all';
    function statPill(label, value, status) {
      const isActive = activeStatus === status;
      const base = 'display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:20px;font-size:13px;text-decoration:none;border:1px solid;cursor:pointer;white-space:nowrap;transition:opacity .15s;';
      const styles = {
        all:     isActive ? 'background:#1d4ed8;color:#fff;border-color:#1d4ed8;'     : 'background:#f1f5f9;color:#374151;border-color:#cbd5e1;',
        scraped: isActive ? 'background:#1d4ed8;color:#fff;border-color:#1d4ed8;'     : 'background:#f0fdf4;color:#166534;border-color:#86efac;',
        pending: isActive ? 'background:#1d4ed8;color:#fff;border-color:#1d4ed8;'     : 'background:#f8fafc;color:#64748b;border-color:#cbd5e1;',
        on_sale: isActive ? 'background:#1d4ed8;color:#fff;border-color:#1d4ed8;'     : 'background:#fff7ed;color:#9a3412;border-color:#fdba74;',
        error:   isActive ? 'background:#1d4ed8;color:#fff;border-color:#1d4ed8;'     : 'background:#fffbeb;color:#92400e;border-color:#fcd34d;',
        failed:  isActive ? 'background:#dc2626;color:#fff;border-color:#dc2626;'     : 'background:#fef2f2;color:#dc2626;border-color:#fca5a5;',
      };
      const href = status === 'all' ? '/' : '/?status=' + status;
      return `<a href="${href}" style="${base}${styles[status] || styles.all}"><strong>${value}</strong> ${label}</a>`;
    }
  %>
  <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px">
    <%- statPill('productos',    stats.total,     'all') %>
    <%- statPill('con precio',   stats.withPrice, 'scraped') %>
    <%- statPill('sin scrapear', stats.pending,   'pending') %>
    <%- statPill('en oferta',    stats.onSale,    'on_sale') %>
    <%- statPill('con error',    stats.withError, 'error') %>
    <%- statPill('fallidos',     stats.failed,    'failed') %>
  </div>
  <% } %>

  <!-- Add product form -->
  <div class="card add-card">
    <h2>Añadir producto</h2>

    <!-- Single URL -->
    <form
      hx-post="/products"
      hx-target="#product-list"
      hx-swap="beforeend"
      hx-on::after-request="if(event.detail.successful) { this.reset(); location.reload(); }"
      class="add-form"
      id="add-form"
    >
      <div class="input-group">
        <input
          type="url"
          name="url"
          placeholder="https://www.amazon.es/dp/B0XXXXXXXX"
          required
          class="input"
          autocomplete="off"
        >
        <button type="submit" class="btn btn-primary" id="add-btn">Añadir</button>
      </div>
      <p class="hint">Pega la URL de cualquier artículo de Amazon.es</p>
    </form>

    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
    <hr style="border:none;border-top:1px solid #f0f0f0;margin:16px 0">

    <!-- Wishlist -->
    <p style="font-size:13px;font-weight:600;color:var(--gray-500);margin:0 0 8px">Importar wishlist de Amazon</p>
    <form hx-post="/products/import-wishlist" hx-target="#wishlist-result" hx-swap="innerHTML" class="add-form">
      <div class="input-group">
        <input type="url" name="wishlistUrl" placeholder="https://www.amazon.es/hz/wishlist/ls/…" required class="input" autocomplete="off">
        <button type="submit" class="btn btn-outline">Importar</button>
      </div>
      <p class="hint">La wishlist debe ser pública en Amazon</p>
    </form>
    <div id="wishlist-result"></div>

    <hr style="border:none;border-top:1px solid #f0f0f0;margin:16px 0">

    <!-- Import from URL (admin) -->
    <p style="font-size:13px;font-weight:600;color:var(--gray-500);margin:0 0 8px">Importar desde URL</p>
    <form id="import-url-form" autocomplete="off" class="add-form">
      <div class="input-group">
        <input id="import-url-input" type="url" placeholder="https://… blog, comparativa, wishlist…" required class="input" autocomplete="off">
        <button id="import-url-btn" type="submit" class="btn btn-outline">Importar</button>
      </div>
      <p class="hint">Extrae todos los ASINs de Amazon.es que encuentre en la página</p>
    </form>
    <div id="import-url-progress" style="display:none;margin-top:10px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
        <span style="font-size:12px;font-weight:600;color:var(--gray-500)">Progreso</span>
        <span id="import-url-summary" style="font-size:12px;color:var(--gray-500)"></span>
      </div>
      <div id="import-url-log" class="import-log"></div>
    </div>
    <% } %>
  </div>

  <!-- Filter bar -->
  <% if (stats.total > 0) { %>
  <form class="filter-bar" method="get" action="/" id="filter-form">
    <input type="text" name="q" id="filter-q" value="<%= filters.q %>" placeholder="Buscar producto…" class="input input-sm" style="flex:1; min-width:160px" autocomplete="off">
    <select name="category" class="input input-sm" onchange="this.form.submit()">
      <option value="">Todas las categorías</option>
      <option value="none" <%= filters.category === 'none' ? 'selected' : '' %>>Sin categoría</option>
      <% allCategories.forEach(function(cat) { %>
        <option value="<%= cat.id %>" <%= filters.category === String(cat.id) ? 'selected' : '' %>><%= cat.name %></option>
      <% }); %>
    </select>
    <select name="status" class="input input-sm" onchange="this.form.submit()">
      <option value="all"         <%= filters.status === 'all'         ? 'selected' : '' %>>Todos</option>
      <option value="scraped"     <%= filters.status === 'scraped'     ? 'selected' : '' %>>Con precio</option>
      <option value="on_sale"     <%= filters.status === 'on_sale'     ? 'selected' : '' %>>En oferta</option>
      <option value="unavailable" <%= filters.status === 'unavailable' ? 'selected' : '' %>>Sin stock</option>
      <option value="error"       <%= filters.status === 'error'       ? 'selected' : '' %>>Con error</option>
      <option value="failed"      <%= filters.status === 'failed'      ? 'selected' : '' %>>Fallidos</option>
      <option value="pending"     <%= filters.status === 'pending'     ? 'selected' : '' %>>Sin scrapear</option>
    </select>
    <select name="sort" class="input input-sm" style="width:auto" onchange="this.form.submit()">
      <option value="recent"     <%= filters.sort === 'recent'     ? 'selected' : '' %>>Más recientes</option>
      <option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Precio: mayor a menor</option>
      <option value="price_asc"  <%= filters.sort === 'price_asc'  ? 'selected' : '' %>>Precio: menor a mayor</option>
      <option value="discount"   <%= filters.sort === 'discount'   ? 'selected' : '' %>>Mayor descuento %</option>
    </select>
    <select name="per_page" class="input input-sm" style="width:auto" onchange="this.form.submit()">
      <% [10,20,50].forEach(function(n) { %>
        <option value="<%= n %>" <%= filters.perPage === n ? 'selected' : '' %>><%= n %> / pág.</option>
      <% }); %>
    </select>
    <% const isFiltered = filters.q || filters.category || filters.status !== 'all' || filters.sort !== 'recent'; %>
    <% if (isFiltered) { %>
      <a href="/" class="btn btn-sm btn-ghost" title="Limpiar filtros" style="padding:0 8px;font-size:16px;line-height:1">×</a>
    <% } %>
  </form>
  <script>
    (function () {
      var t, input = document.getElementById('filter-q');
      if (!input) return;
      input.addEventListener('input', function () {
        clearTimeout(t);
        t = setTimeout(function () { document.getElementById('filter-form').submit(); }, 500);
      });
    })();
  </script>
  <% } %>

  <!-- Bulk action bar (admin only) -->
  <% if (typeof isAdmin !== 'undefined' && isAdmin && stats.total > 0) { %>
  <div class="bulk-bar" id="bulk-bar">
    <button type="button" onclick="selectAllVisible()" class="btn btn-sm btn-ghost">Todos</button>
    <button type="button" onclick="clearSelection()" class="btn btn-sm btn-ghost">Ninguno</button>
    <span id="bulk-count" class="hint" style="min-width:90px"></span>
    <select id="bulk-category" class="input input-sm" style="max-width:200px">
      <option value="">— Sin categoría —</option>
      <% allCategories.forEach(function(cat) { %>
        <option value="<%= cat.id %>"><%= cat.name %></option>
      <% }); %>
    </select>
    <button type="button" id="bulk-assign-btn" onclick="assignBulkCategory()" class="btn btn-sm btn-primary" disabled>Asignar categoría</button>
    <span id="bulk-result" class="hint" style="color:var(--green)"></span>
  </div>
  <% } %>

  <!-- Products grid -->
  <div class="product-grid" id="product-list">
  <% if (products.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">🛒</div>
      <h3>No hay productos todavía</h3>
      <p>Añade la URL de un artículo de Amazon.es para empezar a hacer seguimiento de su precio.</p>
    </div>
  <% } else { %>
    <% products.forEach(function(p) {
      const isAtLow = p.isAvailable && p.currentPrice && p.minPrice && parseInt(p.checkCount, 10) >= 360 && parseFloat(p.currentPrice) <= parseFloat(p.minPrice) + 0.01;
    %>
    <div class="product-card" id="product-<%= p.id %>" data-product-id="<%= p.id %>">
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
      <label class="product-select-label" onclick="event.stopPropagation()">
        <input type="checkbox" class="product-checkbox" data-id="<%= p.id %>">
      </label>
      <% } %>
      <a href="/products/<%= p.id %>" class="product-card-link">
        <div class="product-img-wrap">
          <% if (p.imageUrl) { %>
            <img src="<%= p.imageUrl %>" alt="<%= p.name ?? p.asin %>" class="product-img" loading="lazy">
          <% } else { %>
            <div class="product-img-placeholder">📦</div>
          <% } %>
          <% if (p.isFailed) { %>
            <span class="badge-unavailable" style="background:#dc2626" title="Fallo en scraping 3 veces seguidas — pausado">Fallido</span>
          <% } else if (isAtLow) { %>
            <span class="badge-low" title="Precio en mínimo desde que se inició el seguimiento">Precio mínimo</span>
          <% } else if (p.isOnSale) { %>
            <span class="badge-sale" title="Bajada superior al 7% respecto al registro anterior">Oferta</span>
          <% } else if (!p.isAvailable) { %>
            <span class="badge-unavailable" title="Actualmente sin stock en Amazon">Sin stock</span>
          <% } %>
        </div>
        <div class="product-info">
          <p class="product-name"><%= p.name ?? p.asin %></p>
          <p class="product-asin">ASIN: <%= p.asin %><% if (p.isPublic) { %> · <span class="public-tag">público</span><% } %><% if (typeof isAdmin !== 'undefined' && isAdmin && !p.isOwnProduct) { %> · <span class="hint" style="color:var(--gray-400)">sistema</span><% } %></p>
          <% if (p.categoryName) { %><a href="/c/<%= p.categorySlug %>" class="category-tag"><%= p.categoryName %></a><% } %>
          <% if (p.lastError) { %>
            <p class="product-error">⚠ <%= p.lastError %></p>
          <% } %>
        </div>
      </a>

      <div class="product-prices">
        <% if (!p.isAvailable) { %>
          <div class="price-unavailable">Sin stock</div>
          <% if (p.minPrice) { %>
            <div class="price-range">
              <span class="price-min" title="Precio mínimo registrado">↓ <%= parseFloat(p.minPrice).toFixed(2) %> €</span>
              <span class="price-max" title="Precio máximo registrado">↑ <%= parseFloat(p.maxPrice).toFixed(2) %> €</span>
            </div>
          <% } %>
        <% } else if (p.currentPrice) { %>
          <div class="price-row">
            <div class="price-current"><%= parseFloat(p.currentPrice).toFixed(2) %> €</div>
            <%- trendBadge(p.currentPrice, p.previousPrice) %>
          </div>
          <%- sparklineSvg(p.sparklineData, 80, 28) %>
          <% if (p.minPrice && p.maxPrice) { %>
            <div class="price-range">
              <span class="price-min" title="Precio mínimo registrado">↓ <%= parseFloat(p.minPrice).toFixed(2) %> €</span>
              <span class="price-max" title="Precio máximo registrado">↑ <%= parseFloat(p.maxPrice).toFixed(2) %> €</span>
            </div>
          <% } %>
          <div class="price-checks"><%= p.checkCount %> registros</div>
        <% } else { %>
          <div class="price-pending">Cargando…</div>
        <% } %>
      </div>

      <div class="product-actions">
        <a href="/products/<%= p.id %>" class="btn btn-sm btn-outline">Ver historial</a>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <button
            class="btn btn-sm public-toggle"
            data-id="<%= p.id %>"
            style="<%= p.isPublic ? 'background:#16a34a;color:#fff;border-color:#16a34a' : 'opacity:.6' %>"
          ><%= p.isPublic ? 'Público' : 'Privado' %></button>
          <% if (p.consecutiveFailures > 0 || p.totalFailures > 0) { %>
            <span style="display:flex;flex-direction:column;align-items:center;font-size:10px;line-height:1.3;color:<%= p.isFailed ? '#dc2626' : '#b45309' %>;white-space:nowrap">
              <span><%= p.consecutiveFailures %>/3</span>
              <span><%= p.totalFailures %> tot</span>
            </span>
          <% } %>
          <button
            class="btn btn-sm btn-ghost refresh-card-btn"
            data-id="<%= p.id %>"
            title="Actualizar precio"
            style="padding:0 7px;font-size:15px"
          >↺</button>
        <% } %>
        <button
          class="btn btn-sm btn-danger"
          hx-delete="/products/<%= p.id %>"
          hx-target="#product-<%= p.id %>"
          hx-swap="outerHTML"
          hx-confirm="¿Eliminar este producto y todo su historial de precios?"
          title="Eliminar producto"
          style="padding:0 8px;font-size:15px;font-weight:700"
        >×</button>
      </div>
    </div>
    <% }); %>
  <% } %>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
  <div class="pagination">
    <% const pageBase = '/?q=' + encodeURIComponent(filters.q) + '&category=' + filters.category + '&status=' + filters.status + '&sort=' + filters.sort + '&per_page=' + filters.perPage; %>
    <% if (page > 1) { %>
      <a href="<%= pageBase %>&page=<%= page - 1 %>" class="btn btn-sm btn-outline">← Anterior</a>
    <% } %>
    <span class="hint" style="align-self:center">Página <%= page %> de <%= totalPages %> (<%= totalCount %> productos)</span>
    <% if (page < totalPages) { %>
      <a href="<%= pageBase %>&page=<%= page + 1 %>" class="btn btn-sm btn-outline">Siguiente →</a>
    <% } %>
  </div>
  <% } %>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> &nbsp;·&nbsp; Amazon.es Price Tracker<% if (process.env.TELEGRAM_PUBLIC_CHANNEL) { %> &nbsp;·&nbsp; <a href="https://t.me/<%= process.env.TELEGRAM_PUBLIC_CHANNEL.replace('@','') %>" target="_blank" rel="noopener">📢 Telegram</a><% } %></p>
</footer>

<% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
<script>
(function () {
  const selectedIds = new Set();
  let dragActive = false;
  let dragAction = null; // 'add' | 'remove'
  let dragStartPos = null;
  const DRAG_THRESHOLD = 6;

  function updateUI() {
    // Clean up ids whose cards were removed from the DOM
    document.querySelectorAll('.product-card[data-product-id]').forEach(() => {});
    const domIds = new Set([...document.querySelectorAll('.product-card[data-product-id]')]
      .map(c => parseInt(c.dataset.productId)));
    for (const id of selectedIds) { if (!domIds.has(id)) selectedIds.delete(id); }

    const count = selectedIds.size;
    const countEl = document.getElementById('bulk-count');
    const assignBtn = document.getElementById('bulk-assign-btn');
    if (countEl) countEl.textContent = count > 0 ? count + ' seleccionado' + (count !== 1 ? 's' : '') : '';
    if (assignBtn) assignBtn.disabled = count === 0;

    document.querySelectorAll('.product-checkbox').forEach(cb => {
      const id = parseInt(cb.dataset.id);
      cb.checked = selectedIds.has(id);
      const card = cb.closest('.product-card');
      if (card) card.classList.toggle('bulk-selected', selectedIds.has(id));
    });
  }

  window.selectAllVisible = function () {
    document.querySelectorAll('.product-checkbox').forEach(cb => selectedIds.add(parseInt(cb.dataset.id)));
    updateUI();
  };

  window.clearSelection = function () {
    selectedIds.clear();
    document.getElementById('bulk-result').textContent = '';
    updateUI();
  };

  window.assignBulkCategory = async function () {
    if (!selectedIds.size) return;
    const categoryId = document.getElementById('bulk-category').value;
    const btn = document.getElementById('bulk-assign-btn');
    btn.disabled = true;
    btn.textContent = 'Asignando…';

    try {
      const res = await fetch('/products/bulk-set-category', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids: [...selectedIds], categoryId })
      });
      if (res.ok) {
        const data = await res.json();
        document.getElementById('bulk-result').textContent = '✓ ' + data.updated + ' actualizado' + (data.updated !== 1 ? 's' : '');
        clearSelection();
        setTimeout(() => location.reload(), 900);
      }
    } finally {
      btn.textContent = 'Asignar categoría';
    }
  };

  // Checkbox change
  document.addEventListener('change', function (e) {
    if (!e.target.classList.contains('product-checkbox')) return;
    const id = parseInt(e.target.dataset.id);
    if (e.target.checked) selectedIds.add(id); else selectedIds.delete(id);
    updateUI();
  });

  // Drag-to-select
  function cardAt(x, y) {
    const el = document.elementFromPoint(x, y);
    return el ? el.closest('.product-card[data-product-id]') : null;
  }

  document.addEventListener('mousedown', function (e) {
    if (e.button !== 0) return;
    if (e.target.closest('button') || e.target.closest('.product-actions')) return;
    const card = e.target.closest('.product-card[data-product-id]');
    if (!card) return;
    dragStartPos = { x: e.clientX, y: e.clientY };
    const id = parseInt(card.dataset.productId);
    dragAction = selectedIds.has(id) ? 'remove' : 'add';
  });

  document.addEventListener('mousemove', function (e) {
    if (!dragStartPos) return;
    const dx = Math.abs(e.clientX - dragStartPos.x);
    const dy = Math.abs(e.clientY - dragStartPos.y);
    if (!dragActive && (dx > DRAG_THRESHOLD || dy > DRAG_THRESHOLD)) {
      dragActive = true;
      dragStartPos = null;
    }
    if (!dragActive) return;
    const card = cardAt(e.clientX, e.clientY);
    if (card) {
      const id = parseInt(card.dataset.productId);
      if (!isNaN(id)) {
        if (dragAction === 'add') selectedIds.add(id); else selectedIds.delete(id);
        updateUI();
      }
    }
  });

  // Intercept click ONLY when a real drag happened, to prevent link navigation
  document.addEventListener('click', function (e) {
    if (dragActive) { e.preventDefault(); e.stopPropagation(); dragActive = false; }
  }, true);

  document.addEventListener('mouseup', function () { dragStartPos = null; dragActive = false; });

  // Prevent native browser drag from interfering
  document.querySelectorAll('.product-card').forEach(card => {
    card.addEventListener('dragstart', e => e.preventDefault());
  });
})();
</script>
<% } %>

<% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
<script>
document.addEventListener('click', function(e) {
  const btn = e.target.closest('.public-toggle');
  if (!btn) return;
  const id = btn.dataset.id;
  btn.disabled = true;
  fetch('/products/' + id + '/toggle-public', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      btn.textContent = data.isPublic ? 'Público' : 'Privado';
      btn.style.background    = data.isPublic ? '#16a34a' : '';
      btn.style.color         = data.isPublic ? '#fff'    : '';
      btn.style.borderColor   = data.isPublic ? '#16a34a' : '';
      btn.style.opacity       = data.isPublic ? '1'       : '.6';
    })
    .catch(function(e) { console.error(e); })
    .finally(function() { btn.disabled = false; });
});

document.addEventListener('click', function(e) {
  const btn = e.target.closest('.refresh-card-btn');
  if (!btn) return;
  e.stopPropagation();
  const id = btn.dataset.id;
  btn.disabled = true;
  btn.textContent = '…';
  fetch('/products/' + id + '/refresh', { method: 'POST' })
    .then(function() { location.reload(); })
    .catch(function() { btn.disabled = false; btn.textContent = '↺'; });
});
</script>
<% } %>

<% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
<style>
.import-log { font-family:monospace; font-size:12px; max-height:300px; overflow-y:auto; display:flex; flex-direction:column; gap:2px; }
.log-line   { padding:2px 6px; border-radius:3px; line-height:1.5; }
.log-info   { color:var(--gray-600); }
.log-found  { background:#eff6ff; color:#1d4ed8; font-weight:600; }
.log-add    { background:#f0fdf4; color:#166534; }
.log-skip   { color:var(--gray-400); }
.log-error  { background:#fef2f2; color:#991b1b; }
.log-done   { background:#f0fdf4; color:#166534; font-weight:700; padding:6px 10px; margin-top:4px; border-radius:4px; }
</style>
<script>
(function() {
  const form    = document.getElementById('import-url-form');
  if (!form) return;
  const btn     = document.getElementById('import-url-btn');
  const wrap    = document.getElementById('import-url-progress');
  const log     = document.getElementById('import-url-log');
  const summary = document.getElementById('import-url-summary');
  let es = null;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const url = document.getElementById('import-url-input').value.trim();
    if (!url) return;
    log.innerHTML = '';
    summary.textContent = '';
    wrap.style.display = '';
    btn.disabled = true;
    btn.textContent = 'Importando…';
    if (es) { es.close(); es = null; }
    es = new EventSource('/admin/import-url/stream?url=' + encodeURIComponent(url));
    es.addEventListener('message', function(e) {
      const d = JSON.parse(e.data);
      const div = document.createElement('div');
      div.className = 'log-line log-' + d.type;
      const icons = { info:'→', found:'●', add:'+', skip:'~', error:'✗' };
      div.textContent = (icons[d.type] || '·') + ' ' + d.msg;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
    });
    es.addEventListener('done', function(e) {
      const d = JSON.parse(e.data);
      const div = document.createElement('div');
      div.className = 'log-line log-done';
      div.textContent = '✓ Completado — ' + d.added + ' añadidos · ' + d.skipped + ' ya existían · ' + d.errors + ' errores';
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      summary.textContent = '+' + d.added + ' / ~' + d.skipped + ' / ✗' + d.errors;
      btn.disabled = false;
      btn.textContent = 'Importar';
      es.close(); es = null;
    });
    es.onerror = function() {
      btn.disabled = false;
      btn.textContent = 'Importar';
      if (es) { es.close(); es = null; }
    };
  });
})();
</script>
<% } %>

</body>
</html>
