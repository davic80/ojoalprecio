<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.title.slice(0, 60) %> — AliExpress · OjoAlPrecio</title>
  <meta name="description" content="Sigue el precio de este producto AliExpress y descubre <%= similars.length %> alternativas más baratas en ojoalprecio.com">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof history !== 'undefined' && history.length > 0) { %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3.0.0/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
  <% } %>
</head>
<body>

<%# Using the 'deals'-style navbar (login-aware, no "next=" reference) since
   the 'product' variant assumes Amazon's /p/:asin URL shape for its
   post-login redirect. Cleaner than minting a fake ASIN. -%>
<%- include('partials/navbar', {
  variant: 'deals',
  user: isLogged ? user : null,
  isAdmin: adminMode,
}) %>

<main class="container">

  <div class="back-link"><a href="/ofertas">← Volver</a></div>

  <!-- Marketplace badge — explicit so users (and us) never confuse this with an Amazon listing -->
  <div style="margin-bottom:var(--sp-2)">
    <span class="marketplace-tag marketplace-tag-aliexpress">🛒 AliExpress</span>
  </div>

  <!-- Product header -->
  <div class="product-header">
    <% if (product.imageUrl) { %>
      <a href="<%= product.promotionUrl || product.productUrl %>" target="_blank" rel="noopener sponsored" class="product-img-link">
        <img src="<%= product.imageUrl %>" alt="<%= product.title %>" class="product-detail-img">
      </a>
    <% } %>
    <div class="product-header-info">
      <h1>
        <a href="<%= product.promotionUrl || product.productUrl %>" target="_blank" rel="noopener sponsored" class="product-title-link">
          <%= product.title %>
        </a>
      </h1>
      <p class="product-asin">
        ID: <strong><%= product.productId %></strong>
        <% if (product.shopName) { %> · <span class="hint">por <%= product.shopName %></span><% } %>
      </p>

      <% if (product.rating !== null) { %>
        <p class="hint" style="margin-top:4px">
          <%= product.rating.toFixed(1) %>% positivo
          <% if (product.ordersCount) { %> · <%= Number(product.ordersCount).toLocaleString('es-ES') %> pedidos<% } %>
        </p>
      <% } %>

      <a href="<%= product.promotionUrl || product.productUrl %>" target="_blank" rel="noopener sponsored" class="amazon-link" style="color:var(--aliexpress)">
        Ver en AliExpress ↗
      </a>
    </div>
  </div>

  <!-- Price stats: current, original (if any), rating, orders -->
  <div class="card">
    <div class="price-stats">
      <a href="<%= product.promotionUrl || product.productUrl %>" target="_blank" rel="noopener sponsored" class="stat-box stat-current stat-box-link">
        <div class="stat-label">Precio ↗</div>
        <% if (product.originalPrice && product.discountPct) { %>
          <div style="display:flex;align-items:center;gap:6px;margin-bottom:2px">
            <span style="font-size:13px;text-decoration:line-through;color:var(--gray-400)"><%= product.originalPrice.toFixed(2) %> €</span>
            <span style="font-size:12px;font-weight:700;background:var(--aliexpress);color:#fff;border-radius:4px;padding:1px 5px">-<%= product.discountPct %>%</span>
          </div>
        <% } %>
        <div class="stat-value"><%= product.salePrice ? product.salePrice.toFixed(2) + ' €' : '—' %></div>
      </a>
      <% if (product.ordersCount) { %>
      <div class="stat-box">
        <div class="stat-label">Pedidos</div>
        <div class="stat-value"><%= Number(product.ordersCount).toLocaleString('es-ES') %></div>
      </div>
      <% } %>
      <% if (product.rating !== null) { %>
      <div class="stat-box">
        <div class="stat-label">Satisfacción</div>
        <div class="stat-value"><%= product.rating.toFixed(1) %>%</div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- CTA bar — reuses .cta-bar so the mobile sticky-bottom rule kicks in.
       The button uses .btn-aliexpress (orange) to distinguish from the
       Amazon-blue affiliate button. -->
  <div class="cta-bar">
    <a href="<%= product.promotionUrl || product.productUrl %>" target="_blank" rel="noopener sponsored" class="btn btn-aliexpress">
      Comprar en AliExpress — <%= product.salePrice ? product.salePrice.toFixed(2) + ' €' : 'Ver precio' %>
    </a>
    <% if (!isLogged) { %>
      <a href="/auth/register?next=<%= encodeURIComponent('/ae/' + product.productId) %>" class="btn btn-outline">
        Crear alerta gratis
      </a>
    <% } else if (!isTracking) { %>
      <form method="POST" action="/products" style="display:inline">
        <input type="hidden" name="url" value="https://es.aliexpress.com/item/<%= product.productId %>.html">
        <input type="hidden" name="next" value="/ae/<%= product.productId %>">
        <button type="submit" class="btn btn-outline">+ Seguir este producto</button>
      </form>
    <% } else { %>
      <span class="btn btn-outline" style="cursor:default">✓ Siguiendo</span>
    <% } %>
  </div>

  <!-- Similars -->
  <% if (similars.length > 0) { %>
    <div class="card">
      <h2>Productos similares (<%= similars.length %>)</h2>
      <p class="subtitle">Ordenados por mayor ahorro. Los porcentajes negativos indican el similar es más caro que el producto seguido.</p>

      <div class="similars-list" style="margin-top:var(--sp-4); display:grid; gap:var(--sp-3)">
        <% similars.forEach(function(s) { %>
          <div class="similar-row" style="display:flex; gap:var(--sp-3); padding:var(--sp-3); border:1px solid var(--gray-200); border-radius:var(--radius); background:var(--white)">
            <% if (s.imageUrl) { %>
              <a href="/ae/<%= s.productId %>" style="flex-shrink:0">
                <img src="<%= s.imageUrl %>" alt="" style="width:64px; height:64px; object-fit:contain; border-radius:var(--radius-sm); background:var(--gray-50)">
              </a>
            <% } %>
            <div style="flex:1; min-width:0">
              <a href="/ae/<%= s.productId %>" style="color:var(--gray-900); text-decoration:none; font-weight:500; font-size:var(--fs-base); display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; line-height:1.35">
                <%= s.title %>
              </a>
              <div style="margin-top:var(--sp-1); display:flex; align-items:baseline; gap:var(--sp-2); flex-wrap:wrap">
                <span style="font-size:var(--fs-md); font-weight:700; color:var(--gray-900)">
                  <%= s.salePrice ? s.salePrice.toFixed(2) + ' €' : '—' %>
                </span>
                <% if (s.pctCheaper > 0) { %>
                  <span style="font-size:var(--fs-xs); font-weight:700; color:#15803d; background:#ecfdf5; padding:1px 6px; border-radius:20px">−<%= s.pctCheaper.toFixed(1) %>%</span>
                <% } else if (s.pctCheaper < 0) { %>
                  <span style="font-size:var(--fs-xs); color:var(--gray-400)">+<%= Math.abs(s.pctCheaper).toFixed(1) %>%</span>
                <% } %>
                <% if (s.shopName) { %><span class="hint" style="font-size:var(--fs-xs)"><%= s.shopName %></span><% } %>
              </div>
            </div>
            <a href="<%= s.promotionUrl || s.productUrl %>" target="_blank" rel="noopener sponsored" class="btn btn-sm btn-aliexpress" style="flex-shrink:0; align-self:center">AliExpress ↗</a>
          </div>
        <% }); %>
      </div>
    </div>
  <% } else { %>
    <div class="card">
      <p class="subtitle">Aún no se han encontrado similares para este producto. La búsqueda se reintentará automáticamente cada 8 horas.</p>
    </div>
  <% } %>

  <%# Price history — only renders if we've recorded at least 2 ticks so the
     chart isn't a single dot. With the 8h cadence, the second tick lands
     ~8h after the user first added the product. -%>
  <% if (typeof history !== 'undefined' && history.length >= 2) { %>
    <div class="card chart-card">
      <h2>Historial de precios</h2>
      <p class="subtitle">Actualizado cada 8 horas mediante la API de AliExpress (afiliados).</p>
      <div class="chart-wrap" style="margin-top:var(--sp-3)">
        <canvas id="aePriceChart"></canvas>
      </div>
    </div>

    <div class="card">
      <h2>Últimos registros</h2>
      <div class="table-wrap">
        <table class="price-table table-card-mobile">
          <thead>
            <tr>
              <th>Fecha</th>
              <th>Precio</th>
              <th>Variación</th>
            </tr>
          </thead>
          <tbody>
            <% history.slice(0, 50).forEach(function(h, i, arr) {
              const prev = arr[i + 1];
              const diff = prev ? h.price - prev.price : null;
              const pct  = (prev && prev.price !== 0) ? diff / prev.price * 100 : null;
            %>
              <tr>
                <td data-label="Fecha"><%= new Date(h.scrapedAt).toLocaleString('es-ES') %></td>
                <td data-label="Precio" class="price-cell"><%= h.price.toFixed(2) %> €</td>
                <td data-label="Variación" class="price-cell">
                  <% if (diff !== null && Math.abs(pct) >= 0.1) { %>
                    <span class="<%= diff < 0 ? 'trend-down' : 'trend-up' %>">
                      <%= diff >= 0 ? '+' : '−' %><%= Math.abs(diff).toFixed(2) %> € (<%= diff >= 0 ? '+' : '−' %><%= Math.abs(pct).toFixed(1) %>%)
                    </span>
                  <% } else { %>—<% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <script>
      const chartData = <%- JSON.stringify(
        history.slice().reverse().map(h => ({ x: new Date(h.scrapedAt).toISOString(), y: h.price }))
      ) %>;
      document.addEventListener('DOMContentLoaded', () => {
        const ctx = document.getElementById('aePriceChart').getContext('2d');
        new Chart(ctx, {
          type: 'line',
          data: { datasets: [{
            label: 'Precio (€)', data: chartData,
            borderColor: '#e62e04', backgroundColor: 'rgba(230,46,4,0.08)',
            borderWidth: 2, pointRadius: chartData.length > 100 ? 0 : 3,
            pointHoverRadius: 5, tension: 0.2, fill: true,
          }]},
          options: {
            responsive: true, maintainAspectRatio: false,
            interaction: { intersect: false, mode: 'index' },
            plugins: {
              legend: { display: false },
              tooltip: { callbacks: { label: ctx => {
                const price = ctx.parsed.y.toFixed(2) + ' €';
                const idx = ctx.dataIndex;
                if (idx === 0) return price;
                const prev = chartData[idx - 1].y;
                const diff = ctx.parsed.y - prev;
                const pct = (diff / prev * 100);
                if (Math.abs(pct) < 0.1) return price;
                const sign = diff >= 0 ? '+' : '−';
                return price + '   ' + sign + Math.abs(diff).toFixed(2) + ' € (' + sign + Math.abs(pct).toFixed(1) + '%)';
              }}}
            },
            scales: {
              x: { type: 'time', time: { tooltipFormat: 'dd/MM/yyyy HH:mm', displayFormats: { hour: 'dd/MM HH:mm', day: 'dd/MM', month: 'MMM yyyy' } }, ticks: { maxTicksLimit: 6, autoSkip: true, maxRotation: 0 }, grid: { color: 'rgba(0,0,0,0.05)' } },
              y: { ticks: { callback: v => v.toFixed(2) + ' €' }, grid: { color: 'rgba(0,0,0,0.05)' } }
            }
          }
        });
      });
    </script>
  <% } %>

  <p class="hint" style="text-align:center; margin-top:var(--sp-4); font-size:var(--fs-xs)">
    Última actualización: <%= product.lastFetchedAt ? new Date(product.lastFetchedAt).toLocaleString('es-ES') : 'nunca' %>
  </p>

</main>

<%- include('partials/footer', { middleHtml: 'Seguimiento de precios en AliExpress &nbsp;·&nbsp; <a href="/auth/register">Crea tu cuenta gratis</a>' }) %>

<%- include('partials/bottom-nav', { user: isLogged ? user : null, activeNav: 'ofertas' }) %>

</body>
</html>
