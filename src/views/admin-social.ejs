<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Social — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/admin/categories" class="nav-link">Categorías</a>
    <a href="/admin/deals" class="nav-link">Chollos</a>
    <a href="/admin/social" class="nav-link nav-link-active">Social</a>
    <a href="/admin/stats" class="nav-link">Stats</a>
    <a href="/admin/users" class="nav-link">Usuarios</a>
    <span id="scrape-widget" style="position:relative;margin-right:4px"></span>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<main class="container">

  <div class="page-header">
    <h1>Social — Oferta del día</h1>
    <p class="subtitle">Se publica automáticamente a las <%= postHours.map(function(h){ return h + ':00'; }).join(', ') %>. El producto con mayor bajada vs mediana 30d que no se haya publicado en los últimos 7 días.</p>
  </div>

  <!-- Countdown -->
  <div class="stats-bar" style="margin-bottom:16px">
    <div class="stat-pill">
      <span class="stat-pill-value" id="next-post-time">—</span>
      <span class="stat-pill-label">próxima publicación</span>
    </div>
    <div class="stat-pill" style="background:#eff6ff">
      <span class="stat-pill-value" id="next-post-countdown" style="font-variant-numeric:tabular-nums;letter-spacing:1px">—</span>
      <span class="stat-pill-label">tiempo restante</span>
    </div>
  </div>

  <!-- Próxima publicación -->
  <div class="card" style="margin-bottom:16px">
    <h2>Próximo post</h2>
    <% if (!nextDeal) { %>
      <p class="hint" style="margin-top:12px">No hay chollos disponibles ahora mismo (ningún producto público en oferta sin publicar esta semana).</p>
    <% } else { %>
      <div style="margin-top:16px;display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap">
        <div style="flex:1;min-width:200px">
          <p style="font-weight:600;font-size:15px;margin:0 0 6px">
            <a href="/products/<%= nextDeal.id %>" class="hint-link"><%= nextDeal.name ?? nextDeal.asin %></a>
          </p>
          <p style="margin:0 0 4px;font-size:14px;color:var(--gray-500)">ASIN: <code><%= nextDeal.asin %></code></p>
          <p style="margin:0;font-size:22px;font-weight:700;color:#e63946"><%= parseFloat(nextDeal.currentPrice).toFixed(2) %> €
            <span style="font-size:14px;color:#16a34a;font-weight:600">−<%= parseFloat(nextDeal.pctOffMedian).toFixed(1) %>% vs mediana</span>
          </p>
        </div>
        <form action="/admin/social/post-now" method="POST">
          <button type="submit" class="btn btn-primary" onclick="return confirm('¿Publicar ahora en Telegram?')">
            Publicar en Telegram ↑
          </button>
        </form>
      </div>

      <%
        const siteUrl = process.env.SITE_URL ?? 'https://ojoalprecio.com';
        const pct = parseFloat(nextDeal.pctOffMedian).toFixed(1);
        const price = parseFloat(nextDeal.currentPrice).toFixed(2);
        const name = nextDeal.name ? (nextDeal.name.length > 80 ? nextDeal.name.slice(0,80) + '…' : nextDeal.name) : nextDeal.asin;
        const amzUrl = nextDeal.url + (nextDeal.url.includes('?') ? '&' : '?') + 'tag=canidrone-21';
        const histUrl = siteUrl + '/p/' + nextDeal.asin;
        const tweetText = `👁 Oferta del día\n\n${name}\n\n💰 ${price} €  📉 −${pct}% vs precio habitual\n\n🛒 ${amzUrl}\n📊 Historial: ${histUrl}\n\n#chollos #amazon #ofertas #ahorro`;
      %>
      <div style="margin-top:16px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <span style="font-size:13px;font-weight:600;color:var(--gray-500)">Texto para 𝕏 (copiar y pegar)</span>
          <button id="copy-tweet" class="btn btn-sm btn-ghost" style="font-size:12px">Copiar</button>
        </div>
        <textarea id="tweet-text" readonly style="width:100%;height:140px;font-size:13px;font-family:monospace;border:1px solid #e5e7eb;border-radius:6px;padding:10px;resize:none;background:#f9fafb;box-sizing:border-box"><%= tweetText %></textarea>
      </div>
    <% } %>
  </div>

  <!-- Log -->
  <div class="card">
    <h2>Historial de publicaciones</h2>
    <% if (log.length === 0) { %>
      <p class="hint" style="margin-top:12px">Sin publicaciones todavía.</p>
    <% } else { %>
    <div class="table-wrap" style="margin-top:16px">
      <table class="price-table">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Plataforma</th>
            <th>Producto</th>
            <th>Post ID</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% log.forEach(function(row) { %>
            <tr>
              <td style="white-space:nowrap;font-size:12px;color:var(--gray-500)">
                <%= new Date(row.posted_at).toLocaleString('es-ES', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
              </td>
              <td>
                <% if (row.platform === 'twitter') { %>
                  <span style="font-weight:600;color:#000">𝕏</span>
                <% } else { %>
                  <span style="font-weight:600;color:#0088cc">Telegram</span>
                <% } %>
              </td>
              <td style="font-size:13px">
                <% if (row.product_id) { %>
                  <a href="/products/<%= row.product_id %>" class="hint-link">
                    <%= row.name ? (row.name.length > 50 ? row.name.slice(0,50) + '…' : row.name) : row.asin %>
                  </a>
                <% } else { %>
                  <span class="hint">—</span>
                <% } %>
              </td>
              <td style="font-size:12px;color:var(--gray-400)"><%= row.post_id ?? '—' %></td>
              <td>
                <% if (row.content) { %>
                  <button class="btn btn-sm btn-ghost copy-log-tweet" data-content="<%- encodeURIComponent(row.content) %>" style="font-size:12px">Copiar para 𝕏</button>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <div style="margin-top:12px">
    <a href="/" class="hint-link">← Volver al dashboard</a>
  </div>

</main>

<footer class="footer">
  <p>OjoAlPrecio v<%= process.env['APP_VERSION'] ?? 'dev' %> Admin &nbsp;·&nbsp; <a href="/ofertas">Ver ofertas públicas</a></p>
</footer>

<script src="/js/scrape-widget.js"></script>
<script>
(function () {
  var POST_HOURS = <%- JSON.stringify(postHours) %>;

  function nextPostDate() {
    var now = new Date();
    for (var i = 0; i < POST_HOURS.length; i++) {
      var d = new Date(now);
      d.setHours(POST_HOURS[i], 0, 0, 0);
      if (d > now) return d;
    }
    var tomorrow = new Date(now);
    tomorrow.setDate(tomorrow.getDate() + 1);
    tomorrow.setHours(POST_HOURS[0], 0, 0, 0);
    return tomorrow;
  }

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    var next = nextPostDate();
    var diff = Math.max(0, next - Date.now());
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    var timeEl = document.getElementById('next-post-time');
    var countEl = document.getElementById('next-post-countdown');
    if (timeEl) timeEl.textContent = pad(next.getHours()) + ':00';
    if (countEl) countEl.textContent = pad(h) + 'h ' + pad(m) + 'm ' + pad(s) + 's';
  }

  tick();
  setInterval(tick, 1000);
})();

function telegramToX(html) {
  return html
    .replace(/<a href="([^"]+)">[^<]*<\/a>/g, '$1')
    .replace(/<b>([^<]*)<\/b>/g, '$1')
    .replace(/<[^>]+>/g, '')
    .replace(/ \| /g, '\n');
}

const btn = document.getElementById('copy-tweet');
if (btn) {
  btn.addEventListener('click', function() {
    const ta = document.getElementById('tweet-text');
    navigator.clipboard.writeText(ta.value).then(function() {
      btn.textContent = '¡Copiado!';
      setTimeout(function() { btn.textContent = 'Copiar'; }, 2000);
    });
  });
}

document.querySelectorAll('.copy-log-tweet').forEach(function(b) {
  b.addEventListener('click', function() {
    const raw = decodeURIComponent(b.dataset.content);
    const text = telegramToX(raw);
    navigator.clipboard.writeText(text).then(function() {
      b.textContent = '¡Copiado!';
      setTimeout(function() { b.textContent = 'Copiar para 𝕏'; }, 2000);
    });
  });
});
</script>
</body>
</html>
