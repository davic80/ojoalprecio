<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuarios — Admin OjoAlPrecio</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👁</text></svg>">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
  <a href="/" class="navbar-brand">
    <span class="brand-icon">👁</span>
    <span class="brand-name">OjoAlPrecio</span>
  </a>
  <div class="navbar-actions">
    <a href="/admin/categories" class="nav-link">Categorías</a>
    <a href="/admin/deals" class="nav-link">Chollos</a>
    <a href="/admin/social" class="nav-link">Social</a>
    <a href="/admin/stats" class="nav-link">Stats</a>
    <a href="/admin/users" class="nav-link nav-link-active">Usuarios</a>
    <a href="/admin/alerts" class="nav-link">Alertas</a>
    <a href="/admin/settings" class="nav-link">Ajustes</a>
    <span id="scrape-widget" style="position:relative;margin-right:4px"></span>
    <a href="/account" class="user-email user-email-link"><%= user.email %></a>
    <form action="/auth/logout" method="POST" style="display:inline">
      <button type="submit" class="btn btn-ghost btn-sm">Salir</button>
    </form>
  </div>
</nav>

<main class="container">

  <div class="page-header">
    <h1>Usuarios registrados</h1>
    <p class="subtitle">Usuarios dados de alta, productos seguidos y alertas configuradas.</p>
  </div>

  <div class="stats-bar" style="margin-bottom:24px">
    <div class="stat-pill">
      <span class="stat-pill-value"><%= totals.total %></span>
      <span class="stat-pill-label">usuarios</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= totals.verified %></span>
      <span class="stat-pill-label">verificados</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= totals.total - totals.verified %></span>
      <span class="stat-pill-label">sin verificar</span>
    </div>
    <div class="stat-pill">
      <span class="stat-pill-value"><%= totals.withTelegram %></span>
      <span class="stat-pill-label">con Telegram</span>
    </div>
  </div>

  <div class="card" style="padding:0;overflow:hidden">
    <table class="data-table" style="width:100%;border-collapse:collapse">
      <thead>
        <tr>
          <th style="text-align:left;padding:12px 16px;font-size:12px;font-weight:600;color:var(--text-muted);border-bottom:1px solid var(--border);white-space:nowrap">Email</th>
          <th style="text-align:center;padding:12px 16px;font-size:12px;font-weight:600;color:var(--text-muted);border-bottom:1px solid var(--border);white-space:nowrap">Estado</th>
          <th style="text-align:right;padding:12px 16px;font-size:12px;font-weight:600;color:var(--text-muted);border-bottom:1px solid var(--border);white-space:nowrap">Productos</th>
          <th style="text-align:right;padding:12px 16px;font-size:12px;font-weight:600;color:var(--text-muted);border-bottom:1px solid var(--border);white-space:nowrap">Alertas activas</th>
          <th style="text-align:right;padding:12px 16px;font-size:12px;font-weight:600;color:var(--text-muted);border-bottom:1px solid var(--border);white-space:nowrap">Notificaciones</th>
          <th style="text-align:right;padding:12px 16px;font-size:12px;font-weight:600;color:var(--text-muted);border-bottom:1px solid var(--border);white-space:nowrap">Registro</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(u, i) { %>
        <tr style="border-bottom:<%= i < users.length - 1 ? '1px solid var(--border)' : 'none' %>">
          <td style="padding:12px 16px;font-size:13px">
            <span style="font-weight:500"><%= u.email %></span>
            <% if (u.telegramChatId) { %>
              <span style="margin-left:6px;font-size:11px;color:#2196f3" title="Telegram configurado">TG</span>
            <% } %>
          </td>
          <td style="padding:12px 16px;text-align:center">
            <% if (u.emailVerified) { %>
              <span class="badge badge-sale" style="font-size:11px">Verificado</span>
            <% } else { %>
              <span class="badge" style="font-size:11px;background:var(--bg-secondary);color:var(--text-muted)">Pendiente</span>
            <% } %>
          </td>
          <td style="padding:12px 16px;text-align:right;font-size:13px;font-weight:600">
            <%= parseInt(u.productCount, 10) %>
          </td>
          <td style="padding:12px 16px;text-align:right;font-size:13px">
            <% const active = parseInt(u.activeAlertCount, 10); const total = parseInt(u.totalAlertCount, 10); %>
            <% if (total > 0) { %>
              <span style="font-weight:600;color:<%= active > 0 ? 'var(--text)' : 'var(--text-muted)' %>"><%= active %></span>
              <% if (total !== active) { %><span style="color:var(--text-muted);font-size:11px"> / <%= total %></span><% } %>
            <% } else { %>
              <span style="color:var(--text-muted)">—</span>
            <% } %>
          </td>
          <td style="padding:12px 16px;text-align:right;font-size:13px">
            <% const events = parseInt(u.alertEventCount, 10); %>
            <% if (events > 0) { %>
              <span style="font-weight:600"><%= events %></span>
            <% } else { %>
              <span style="color:var(--text-muted)">—</span>
            <% } %>
          </td>
          <td style="padding:12px 16px;text-align:right;font-size:12px;color:var(--text-muted);white-space:nowrap">
            <%= new Date(u.createdAt).toLocaleDateString('es-ES', { day:'2-digit', month:'short', year:'numeric' }) %>
          </td>
        </tr>
        <% }); %>
        <% if (users.length === 0) { %>
        <tr>
          <td colspan="6" style="padding:40px;text-align:center;color:var(--text-muted)">No hay usuarios registrados.</td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>

</main>

<script src="/js/scrape-widget.js" defer></script>
</body>
</html>
