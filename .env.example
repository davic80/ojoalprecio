# Environment variables — copy this file to .env and fill in your values
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL credentials for the ojoalprecio-db container
POSTGRES_USER=ojoalprecio
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=ojoalprecio

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email of the admin user — only this user can create/delete categories
ADMIN_EMAIL=your_email@example.com

# ── App ───────────────────────────────────────────────────────────────────────
# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_hex_string

# Set to true when running behind HTTPS (Cloudflare tunnel)
SESSION_COOKIE_SECURE=true

# Public URL of the app (used in email links)
SITE_URL=https://ojoalprecio.yourdomain.com

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get your token at: dash.cloudflare.com → Zero Trust → Networks → Tunnels → your tunnel → Configure
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── Price check schedule (cron expression) ────────────────────────────────────
# Default: every hour. Examples:
#   "0 * * * *"    every hour
#   "*/30 * * * *" every 30 minutes
#   "0 */2 * * *"  every 2 hours
CHECK_INTERVAL_CRON=0 * * * *

# ── Email notifications (SMTP) ────────────────────────────────────────────────
# Works with Gmail using an App Password (not your account password)
# To generate an App Password: myaccount.google.com → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM=your_gmail@gmail.com

# ── Telegram notifications (optional) ────────────────────────────────────────
# Create a bot with @BotFather → get the token
# Get your chat ID writing /start to @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Docker image tag (optional override for docker compose up) ────────────────
# IMAGE_TAG=1.0.0

# ── Host port (port exposed on the Raspberry Pi) ─────────────────────────────
# Change if 8080 is already in use
HOST_PORT=8080
